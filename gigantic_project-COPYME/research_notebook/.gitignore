# research_notebook/ — personal sandbox + GIGANTIC's own AI infrastructure sandbox.
# Per gigantic_project-COPYME/ai/ai_FYIs/gigantic_conventions.md §1, §9, §25.
#
# What ships:
#   - This .gitignore
#   - README.md at any depth (including research_notebook/README.md
#     and research_ai/README.md)
#   - .gitkeep at any depth (preserves directory structure for git)
#
# What does NOT ship:
#   - research_user/** — true wild-west sandbox; ships ONLY .gitkeep
#     (no README, no scripts, no pipeline code, no anything else)
#   - research_ai/sessions/*.jsonl.gz — captured session transcripts
#     (gitignored by the catch-all below; never edited / deleted)
#   - research_ai/sessions/TRANSCRIPT_CAPTURE_LOG.md — per-project local
#     capture log (also caught by the catch-all)
#   - Any other content (personal notes, draft analyses, downloaded data)

# Default: ignore everything in this tree
*

# Allow traversal into subdirectories (so the rules below can match)
!*/

# Keep this .gitignore
!.gitignore

# Keep README.md at any depth (project-wide doc-ships convention)
!README.md

# Keep .gitkeep stubs (preserve directory structure for git)
!.gitkeep

# research_user/ is a wild-west sandbox per §25 — ships ONLY the .gitkeep.
# Override the !README.md and any other un-ignore specifically inside
# research_user/ so nothing leaks regardless of what the user puts there.
research_user/**
!research_user/.gitkeep

# Archive directories: anything starting with x_ is a disposable archive and
# must stay ignored even if it contains files that would otherwise be tracked
# (e.g., .gitkeep files moved during archival). Place AFTER exceptions so this
# rule wins for x_-prefixed paths.
x_*
**/x_*
