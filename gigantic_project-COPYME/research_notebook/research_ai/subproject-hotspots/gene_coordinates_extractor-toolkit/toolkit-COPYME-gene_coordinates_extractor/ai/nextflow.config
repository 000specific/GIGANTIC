/*
 * Gene Coordinates Extractor Toolkit - NextFlow config
 * AI: Claude Code | Opus 4.7 | 2026 May 29
 * Human: Eric Edsinger
 */

params {
    annotations_dir = null
    hotspots_gene_coordinates_dir = null
    species_whitelist = ""
    output_dir = "OUTPUT_pipeline"
    project_name = "gigantic_project"

    local_cpus       = 2
    local_memory_gb  = 15
    local_time_hours = 1
}

executor {
    name = 'local'
    cpus = params.local_cpus as Integer
    memory = "${params.local_memory_gb} GB"
}

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxErrors = 0

    cpus   = params.local_cpus as Integer
    memory = "${params.local_memory_gb} GB"
    time   = "${params.local_time_hours}h"

    withLabel: 'local' {
        cpus   = params.local_cpus as Integer
        memory = "${params.local_memory_gb} GB"
        time   = "${params.local_time_hours}h"
    }
}

manifest {
    name = 'gene_coordinates_extractor-toolkit'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Extract per-species gene-coordinate TSVs from GFF3 files for the hotspots subproject'
    version = '1.0.0'
    nextflowVersion = '>=24.0.0,<26.0.0'
}
