/*
 * Phyloname Tree Generator Toolkit - NextFlow config
 * AI: Claude Code | Opus 4.7 | 2026 May 29
 * Human: Eric Edsinger
 */

params {
    phylonames                   = null
    config_file                  = null
    trees_species_input_user_dir = null
    prefix                       = "species_tree"
    seed                         = 42
    output_dir                   = "OUTPUT_pipeline"
    project_name                 = "gigantic_project"

    local_cpus       = 2
    local_memory_gb  = 15
    local_time_hours = 1
}

executor {
    name = 'local'
    cpus = params.local_cpus as Integer
    memory = "${params.local_memory_gb} GB"
}

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxErrors = 0

    cpus   = params.local_cpus as Integer
    memory = "${params.local_memory_gb} GB"
    time   = "${params.local_time_hours}h"

    withLabel: 'local' {
        cpus   = params.local_cpus as Integer
        memory = "${params.local_memory_gb} GB"
        time   = "${params.local_time_hours}h"
    }
}

manifest {
    name = 'phyloname_tree_generator-toolkit'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Generate a binary species-tree Newick from a phylonames TSV map (user backbone + optional internal-clade constraints + reproducible random polytomy resolution)'
    version = '1.0.0'
    nextflowVersion = '>=24.0.0,<26.0.0'
}
