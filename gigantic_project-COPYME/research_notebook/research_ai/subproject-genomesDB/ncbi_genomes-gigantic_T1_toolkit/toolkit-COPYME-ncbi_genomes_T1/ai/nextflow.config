/*
 * GIGANTIC NCBI Genomes T1 Toolkit -- NextFlow Configuration
 * AI:    Claude Code | Opus 4.7 (1M context) | 2026 May 28
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit ../START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (Python yaml.safe_load -> json.dump,
 * no flatten) into .params.json and NextFlow loads it via -params-file. All
 * yaml keys become params.X.Y.Z here through that mechanism -- params shape
 * mirrors the yaml shape (nested keys preserved).
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 *   - No top-level `workflow.onComplete {}` block in main.nf
 *     (completion summary handled by RUN-workflow.sh wrap script).
 *
 * Conda env (ai/conda_environment.yml) pins nextflow >=23.04, <26.0 to insulate
 * the toolkit from further 26.x parser regressions until the framework migrates.
 *
 * Pattern: A (Sequential) - executor = 'local'
 * All 5 processes run sequentially within a single job.
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested).

params {
    toolkit {
        name          = 'ncbi_genomes_T1_toolkit'
        manifest_path = 'INPUT_user/ncbi_genomes_manifest.tsv'
        // download_date is resolved from 'auto' / blank to 'downloaded_YYYYMMDD'
        // by RUN-workflow.sh's Python heredoc before being written into .params.json.
        download_date = 'downloaded_YYYYMMDD'
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    resume = false
}

// ============================================================================
// EXECUTOR  (Pattern A: local, sequential)
// ============================================================================

executor {
    name = 'local'
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Fail-fast per gigantic_conventions.md §36
    errorStrategy = 'terminate'
    maxErrors     = 0

    cpus   = 2
    memory = '8 GB'
    time   = '6h'
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name            = 'GIGANTIC-NCBI-Genomes-T1-Toolkit'
    author          = 'Eric Edsinger (with Claude Code AI)'
    description     = 'Download NCBI genome bundles, T1-extract with alt-loci filtering, rename to GIGANTIC convention, auto-bridge to INPUT_user.'
    version         = '2.0.0'
    nextflowVersion = '>=23.04.0,<26.0.0'
}
