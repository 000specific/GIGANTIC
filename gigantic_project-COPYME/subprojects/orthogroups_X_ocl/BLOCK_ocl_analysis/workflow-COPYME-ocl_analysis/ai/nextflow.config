/*
 * ==============================================================================
 * NEXTFLOW CONFIGURATION - GIGANTIC OCL PIPELINE
 * ==============================================================================
 * AI: Claude Code | Opus 4.6 | 2026 April 13
 * Human: Eric Edsinger
 * ==============================================================================
 *
 *  ⚠️  IMPORTANT FOR USERS:
 *
 *  Values that users normally adjust for a specific run live in
 *  `START_HERE-user_config.yaml` — NOT here. `RUN-workflow.sh` reads them from
 *  that yaml and injects them into this config via `nextflow run --KEY value`
 *  so they become `params.KEY` below.
 *
 *  Currently plumbed through from config.yaml:
 *    slurm_account      ← config.yaml `slurm_account`
 *    slurm_qos          ← config.yaml `slurm_qos`
 *
 *  If you change one of those in config.yaml, RUN-workflow.sh handles the
 *  propagation automatically. Do NOT hand-edit duplicates here — that is the
 *  out-of-sync footgun this pattern exists to avoid.
 *
 *  Things that stay here (per-process resource tuning, executor internals)
 *  are lower-level knobs that almost never need user adjustment. Edit with
 *  care; they are NOT driven by config.yaml.
 *
 * ==============================================================================
 * Configuration for running the OCL (Origin-Conservation-Loss) pipeline
 * on HiPerGator SLURM cluster.
 *
 * Resource allocations based on operational experience with the existing
 * OCL pipeline processing 212,278 orthogroups across 67 species and
 * 105 tree structures.
 * ==============================================================================
 */

// ============================================================================
// GENERAL SETTINGS
// ============================================================================

// Enable DSL2 syntax
nextflow.enable.dsl = 2

// Workflow metadata
manifest {
    name = 'GIGANTIC_OCL_Pipeline'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Origin-Conservation-Loss analysis across phylogenetic species tree structures'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// PARAMETERS
// ============================================================================

params {
    // Configuration file (relative to ai/ directory)
    config = "${baseDir}/../START_HERE-user_config.yaml"

    // Structure manifest (overrides config if provided)
    structure_manifest = null

    // Output directory (overrides config if provided)
    output_dir = null

    // SLURM configuration — DO NOT hardcode real values here.
    // These are fallbacks only; RUN-workflow.sh injects the real values from
    // START_HERE-user_config.yaml via `nextflow run --slurm_account=X --slurm_qos=Y`.
    // Leaving these empty makes misconfiguration fail fast rather than silently
    // submitting jobs to someone else's allocation.
    slurm_account = ''
    slurm_qos = ''
}

// ============================================================================
// EXECUTOR CONFIGURATION - HIPERGATOR SLURM
// ============================================================================

executor {
    name = 'slurm'
    queueSize = 50              // Maximum number of jobs to submit at once
    submitRateLimit = '10/1min' // Submit max 10 jobs per minute
    pollInterval = '30 sec'     // Check job status every 30 seconds
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    // Default executor
    executor = 'slurm'

    // Default resource allocations
    cpus = 1
    memory = '4 GB'
    time = '24h'

    // SLURM-specific settings
    clusterOptions = "--account=${params.slurm_account} --qos=${params.slurm_qos}"

    // Error handling - strict fail-fast for research pipelines
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0  // Stop immediately on first failure

    // ========================================================================
    // PROCESS-SPECIFIC RESOURCE REQUIREMENTS
    // ========================================================================

    // Script 001: Prepare inputs (loads large ID mapping + orthogroup + proteome data)
    withName: prepare_inputs {
        cpus = 2
        memory = '14 GB'
        time = '24h'
        maxForks = 20  // Limit concurrent structures to prevent NFS I/O storm
    }

    // Script 002: Determine origins (moderate compute - MRCA algorithm)
    withName: determine_origins {
        cpus = 1
        memory = '4 GB'
        time = '24h'
    }

    // Script 003: Quantify conservation/loss (moderate compute - TEMPLATE_03)
    withName: quantify_conservation_loss {
        cpus = 1
        memory = '4 GB'
        time = '24h'
    }

    // Script 004: Comprehensive analysis (heavier compute - integration)
    withName: comprehensive_ocl_analysis {
        cpus = 1
        memory = '8 GB'
        time = '24h'
    }

    // Script 005: Validation (lightweight - data verification only)
    withName: validate_results {
        cpus = 1
        memory = '4 GB'
        time = '24h'
    }
}

// ============================================================================
// REPORT AND TRACE OPTIONS
// ============================================================================

// Generate execution report
report {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_report.html"
    overwrite = true
}

// Generate execution timeline
timeline {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_timeline.html"
    overwrite = true
}

// Generate execution trace
trace {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_trace.txt"
    overwrite = true
    fields = 'task_id,hash,native_id,name,status,exit,submit,duration,realtime,%cpu,peak_rss,peak_vmem'
}

// Generate execution DAG (directed acyclic graph)
dag {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_dag.html"
    overwrite = true
}

// ============================================================================
// PROFILES
// ============================================================================

profiles {
    // HiPerGator SLURM (default)
    hipergator {
        process.executor = 'slurm'
    }

    // Standard profile
    standard {
        process.executor = 'slurm'
    }

    // Local execution (for testing with single structure)
    local {
        process {
            executor = 'local'
            cpus = 1
            memory = '8 GB'
        }
        executor {
            name = 'local'
            cpus = 4
            memory = '16 GB'
        }
    }

    // Test profile (single structure, local execution)
    test {
        process {
            executor = 'local'
            cpus = 1
            memory = '8 GB'
        }
    }
}

// ============================================================================
// CLEANUP OPTIONS
// ============================================================================

// Do not auto-delete work directory (keep for debugging)
cleanup = false
