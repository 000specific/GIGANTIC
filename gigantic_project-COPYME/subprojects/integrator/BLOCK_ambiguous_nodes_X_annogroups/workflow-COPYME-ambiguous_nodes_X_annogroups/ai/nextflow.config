/*
 * ==============================================================================
 * NEXTFLOW CONFIGURATION - GIGANTIC integrator / ambiguous_nodes_X_annogroups
 * ==============================================================================
 * AI: Claude Code | Opus 4.8 (1M context) | 2026 June 27
 * Human: Eric Edsinger
 * ==============================================================================
 *
 *  IMPORTANT FOR USERS:
 *
 *  Values you normally adjust for a run live in START_HERE-user_config.yaml —
 *  NOT here. RUN-workflow.sh reads them from that yaml and passes the file via
 *  `-params-file`, so params.X.Y.Z mirror the yaml shape. SLURM account/qos and
 *  cpus/memory_gb are injected as params and consumed below.
 *
 *  Things that stay here (per-process resource tuning, executor internals) are
 *  low-level knobs that rarely need user adjustment.
 * ==============================================================================
 */

// Enable DSL2 syntax
nextflow.enable.dsl = 2

manifest {
    name = 'GIGANTIC_integrator_ambiguous_nodes_X_annogroups'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Collapse the annogroups species-tree deconvolution to only the ambiguous nodes, in one/some/all structure scopes'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// PARAMETERS
// ============================================================================

params {
    config = "${baseDir}/../START_HERE-user_config.yaml"
    output_dir = null

    // SLURM configuration — DO NOT hardcode real values here.
    // RUN-workflow.sh injects the real values from START_HERE-user_config.yaml
    // (via -params-file). Empty defaults make misconfiguration fail fast.
    slurm_account = ''
    slurm_qos = ''

    // Local-executor concurrency — driven by START_HERE-user_config.yaml
    // (cpus, memory_gb) so parallelism_mode=local inside a SLURM allocation
    // uses the full allocation instead of a stale hardcoded ceiling.
    cpus = 2
    memory_gb = 16
}

// ============================================================================
// EXECUTOR CONFIGURATION - HIPERGATOR SLURM
// ============================================================================

executor {
    name = 'slurm'
    queueSize = 50
    submitRateLimit = '10/1min'
    pollInterval = '30 sec'
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'slurm'

    cpus = 1
    memory = '4 GB'
    time = '2h'

    clusterOptions = "--account=${params.slurm_account} --qos=${params.slurm_qos}"

    // Strict fail-fast for research pipelines (per gigantic_conventions §36)
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0  // Stop immediately on first persistent failure

    // ========================================================================
    // PROCESS-SPECIFIC RESOURCE REQUIREMENTS
    // ========================================================================

    // Script 001: header-only reads (deconvolution + per-structure files). Tiny.
    withName: resolve_ambiguous_nodes {
        cpus = 1
        memory = '4 GB'
        time = '1h'
    }

    // Script 002: streaming column projection over the all_structures table
    // (~137k rows x ~250 cols) per source x scope. I/O-bound, modest memory.
    withName: project_annogroups {
        cpus = 2
        memory = '16 GB'
        time = '2h'
    }

    // Script 003: validation re-reads headers + counts rows. Light.
    withName: validate_results {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }
}

// ============================================================================
// REPORT AND TRACE OPTIONS
// ============================================================================

report {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_report.html"
    overwrite = true
}
timeline {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_timeline.html"
    overwrite = true
}
trace {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_trace.txt"
    overwrite = true
    fields = 'task_id,hash,native_id,name,status,exit,submit,duration,realtime,%cpu,peak_rss,peak_vmem'
}
dag {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_dag.html"
    overwrite = true
}

// ============================================================================
// PROFILES
// ============================================================================

profiles {
    hipergator {
        process.executor = 'slurm'
    }
    standard {
        process.executor = 'slurm'
    }
    // Local execution (parallelism_mode=local, or standalone testing).
    // Executor concurrency driven by params.cpus / params.memory_gb.
    local {
        process {
            executor = 'local'
            cpus = 1
            memory = '6 GB'
        }
        executor {
            name = 'local'
            cpus = params.cpus as Integer
            memory = "${params.memory_gb} GB"
        }
    }
    test {
        process {
            executor = 'local'
            cpus = 1
            memory = '6 GB'
        }
    }
}

// ============================================================================
// CLEANUP OPTIONS
// ============================================================================

cleanup = false
