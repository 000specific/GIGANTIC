/*
 * GIGANTIC One-Direction Homologs - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 March 31
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from START_HERE-user_config.yaml and sets up NextFlow internals.
 *
 * Supports three execution modes:
 *   - "local":       All processes run locally (sequential)
 *   - "slurm":       All processes run inside one SLURM job (sequential)
 *   - "slurm_burst": DIAMOND splits submitted as individual SLURM burst jobs (parallel)
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File( "${projectDir}/../START_HERE-user_config.yaml" )
    if ( configFile.exists() ) {
        def yaml = new Yaml()
        return yaml.load( configFile.text )
    }
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// EXECUTION MODE DETECTION
// ============================================================================

def executionMode = userConfig?.execution_mode ?: 'local'
def isBurstMode = ( executionMode == 'slurm_burst' )

// ============================================================================
// RESOURCES
// ============================================================================

// Resources for local/slurm modes (single job, sequential)
def resourceCpus = userConfig?.cpus ?: 50
def resourceMemory = "${userConfig?.memory_gb ?: 350} GB"
def resourceTime = "${userConfig?.time_hours ?: 96}h"

// Resources for burst mode (per-chunk SLURM jobs)
def burstCpus = userConfig?.burst_cpus_per_chunk ?: 50
def burstMemory = "${userConfig?.burst_memory_gb_per_chunk ?: 350} GB"
def burstTime = "${userConfig?.burst_time_hours_per_chunk ?: 96}h"
def burstQos = userConfig?.burst_qos ?: ''
def burstAccount = userConfig?.slurm_account ?: ''

// ============================================================================
// PARAMETERS (from START_HERE-user_config.yaml)
// ============================================================================

params {
    // Project settings
    project_name = userConfig?.project?.name ?: "my_project"

    // Input manifest
    proteome_manifest = "${projectDir}/../INPUT_user/proteome_manifest.tsv"

    // DIAMOND settings
    diamond_database = userConfig?.diamond?.database ?: "/path/to/nr.dmnd"
    evalue = userConfig?.diamond?.evalue ?: "1e-5"
    max_target_sequences = userConfig?.diamond?.max_target_sequences ?: 10
    num_parts = userConfig?.diamond?.num_parts ?: 40
    threads_per_job = userConfig?.diamond?.threads_per_job ?: 50

    // Proteome directory (for query length lookup in script 005)
    proteome_directory = userConfig?.proteome_directory ?: "../../../genomesDB-species70/output_to_input/STEP_4-create_final_species_set/species70_gigantic_T1_proteomes"

    // Output directory
    output_dir = "${projectDir}/../OUTPUT_pipeline"
}

// ============================================================================
// EXECUTOR
// ============================================================================

if ( isBurstMode ) {
    // Burst mode: Nextflow orchestrates, submitting DIAMOND jobs to SLURM
    // The executor block sets defaults for lightweight processes;
    // diamond_search overrides to 'slurm' below
    executor {
        name = 'local'
        cpus = 4
        memory = '8 GB'
    }
} else {
    // Local/SLURM modes: everything runs within the current environment
    executor {
        name = 'local'
        cpus = resourceCpus
        memory = resourceMemory
    }
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    // Default: all processes run locally (lightweight steps always local)
    executor = 'local'

    // CRITICAL: Fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0    // Stop immediately on first failure
    maxRetries = 0   // No retries by default

    // Default resources (lightweight processes)
    cpus = 1
    memory = '4 GB'
    time = '2h'

    withName: 'validate_proteomes' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'split_proteomes' {
        memory = '8 GB'
        time = '2h'
    }

    withName: 'diamond_search' {
        if ( isBurstMode ) {
            // Burst mode: each split is its own SLURM job
            executor = 'slurm'
            clusterOptions = "--account=${burstAccount} --qos=${burstQos}"
            cpus = burstCpus
            memory = burstMemory
            time = burstTime
            // Burst QOS jobs can be preempted by higher-priority jobs.
            // Retry preempted chunks automatically instead of killing the pipeline.
            errorStrategy = { task.exitStatus in [143, 140] ? 'retry' : 'terminate' }
            maxRetries = 3
        } else {
            // Local/SLURM: runs within existing allocation
            cpus = params.threads_per_job
            memory = resourceMemory
            time = resourceTime
        }
    }

    withName: 'combine_results' {
        memory = '8 GB'
        time = '2h'
    }

    withName: 'identify_top_hits' {
        memory = '16 GB'
        time = '4h'
    }

    withName: 'compile_statistics' {
        memory = '4 GB'
        time = '1h'
    }
}

// ============================================================================
// NEXTFLOW SLURM QUEUE SETTINGS (burst mode only)
// ============================================================================

if ( isBurstMode ) {
    executor {
        queueSize = 3000           // Max queued tasks
        submitRateLimit = '10 sec' // Throttle SLURM submissions
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-One-Direction-Homologs'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'DIAMOND NCBI nr one-direction homolog search with self/non-self hit analysis'
    version = '2.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
    overwrite = true
}
