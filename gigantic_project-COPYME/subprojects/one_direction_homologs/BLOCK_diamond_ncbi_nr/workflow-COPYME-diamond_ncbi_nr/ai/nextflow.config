/*
 * GIGANTIC One-Direction Homologs - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 / Opus 4.7 | 2026 March 31 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (nested keys preserved).
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 *
 * Supports three execution modes (set via execution_mode in YAML):
 *   - "local":       All processes run locally (sequential)
 *   - "slurm":       All processes run inside one SLURM job (sequential)
 *   - "slurm_burst": DIAMOND splits submitted as individual SLURM burst jobs (parallel)
 *
 * RUN-workflow.sh handles the local/slurm/slurm_burst self-submission;
 * this file picks the right NextFlow executor based on params.execution_mode.
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested + flat).

params {
    project {
        name = 'my_project'
        proteome_manifest = 'INPUT_user/proteome_manifest.tsv'
    }
    diamond {
        database = '/path/to/nr.dmnd'
        evalue = '1e-5'
        max_target_sequences = 10
        num_parts = 40
        threads_per_job = 50
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    proteome_directory = ''
    execution_mode = 'local'
    cpus = 50
    memory_gb = 350
    time_hours = 96
    burst_qos = ''
    burst_cpus_per_chunk = 50
    burst_memory_gb_per_chunk = 350
    burst_time_hours_per_chunk = 96
    slurm_account = ''
    slurm_qos = ''
    resume = false
}

// ============================================================================
// EXECUTOR
// ============================================================================
// NextFlow 26.x strict-DSL: `def X = ...` cannot be mixed with config blocks.
// Inline params.execution_mode == 'slurm_burst' checks where used.

if ( params.execution_mode == 'slurm_burst' ) {
    // Burst mode: Nextflow orchestrates, submitting DIAMOND jobs to SLURM
    // The executor block sets defaults for lightweight processes;
    // diamond_search overrides to 'slurm' below
    executor {
        name = 'local'
        cpus = 4
        memory = '8 GB'
    }
} else {
    // Local/SLURM modes: everything runs within the current environment
    executor {
        name = 'local'
        cpus = params.cpus
        memory = "${params.memory_gb} GB"
    }
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    // Default: all processes run locally (lightweight steps always local)
    executor = 'local'

    // CRITICAL: Fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0    // Stop immediately on first failure
    maxRetries = 0   // No retries by default

    // Default resources (lightweight processes)
    cpus = 1
    memory = '4 GB'
    time = '2h'

    withName: 'validate_proteomes' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'split_proteomes' {
        memory = '8 GB'
        time = '2h'
    }

    withName: 'diamond_search' {
        if ( params.execution_mode == 'slurm_burst' ) {
            // Burst mode: each split is its own SLURM job
            executor = 'slurm'
            clusterOptions = "--account=${params.slurm_account} --qos=${params.burst_qos}"
            cpus = params.burst_cpus_per_chunk
            memory = "${params.burst_memory_gb_per_chunk} GB"
            time = "${params.burst_time_hours_per_chunk}h"
            // Burst QOS jobs can be preempted by higher-priority jobs.
            // Retry preempted chunks automatically instead of killing the pipeline.
            errorStrategy = { task.exitStatus in [143, 140] ? 'retry' : 'terminate' }
            maxRetries = 3
        } else {
            // Local/SLURM: runs within existing allocation
            cpus = params.diamond.threads_per_job
            memory = "${params.memory_gb} GB"
            time = "${params.time_hours}h"
        }
    }

    withName: 'combine_results' {
        memory = '8 GB'
        time = '2h'
    }

    withName: 'identify_top_hits' {
        memory = '16 GB'
        time = '4h'
    }

    withName: 'compile_statistics' {
        memory = '4 GB'
        time = '1h'
    }
}

// ============================================================================
// NEXTFLOW SLURM QUEUE SETTINGS (burst mode only)
// ============================================================================

if ( params.execution_mode == 'slurm_burst' ) {
    executor {
        queueSize = 3000           // Max queued tasks
        submitRateLimit = '10 sec' // Throttle SLURM submissions
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-One-Direction-Homologs'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'DIAMOND NCBI nr one-direction homolog search with self/non-self hit analysis'
    version = '2.1.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

report {
    enabled = true
    file = "${params.output.base_dir}/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.output.base_dir}/pipeline_timeline.html"
    overwrite = true
}
