/*
 * GIGANTIC genomesDB STEP_3 - NextFlow Configuration
 * AI: Claude Code | Opus 4.5 / Opus 4.7 | 2026 February 27 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (nested keys preserved).
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested).

params {
    project {
        name = 'my_project'
    }
    inputs {
        proteomes_dir = '../../output_to_input/STEP_2-standardize_and_evaluate/gigantic_proteomes_cleaned'
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    blast {
        database_name = 'gigantic-T1-blastp'
        parallel_jobs = 4
    }
}

// ============================================================================
// EXECUTOR - Pattern A (Sequential/Local)
// ============================================================================

executor {
    name = 'local'
    cpus = 8
    memory = '32 GB'
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Fail-fast error handling (GIGANTIC standard for research pipelines)
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = 0

    // Default resources
    cpus = 4
    memory = '16 GB'
    time = '4h'

    withLabel: 'local' {
        executor = 'local'
        cpus = 4
        memory = '16 GB'
        time = '4h'
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-genomesDB-STEP_3'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Build per-genome BLAST protein databases'
    version = '1.1.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

report {
    enabled = false
}

timeline {
    enabled = false
}

dag {
    enabled = false
}
