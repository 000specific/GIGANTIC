/*
 * GIGANTIC genomesDB STEP_4 - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 / Opus 4.7 | 2026 February 27 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (nested keys preserved).
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested).

params {
    project {
        name = 'my_project'
    }
    inputs {
        step2_proteomes = '../../output_to_input/STEP_2-standardize_and_evaluate/gigantic_proteomes_cleaned'
        step3_blastp = '../../output_to_input/STEP_3-databases/gigantic-T1-blastp'
        step2_genome_annotations = '../../output_to_input/STEP_2-standardize_and_evaluate/gigantic_genome_annotations'
        selected_species = 'INPUT_user/selected_species.txt'
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
}

// ============================================================================
// EXECUTOR - Pattern A (Sequential/Local)
// ============================================================================

executor {
    name = 'local'
    cpus = 4
    memory = '16 GB'
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Fail-fast error handling (GIGANTIC standard for research pipelines)
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = 0

    // Default resources (STEP_4 is lightweight - just copying files)
    cpus = 2
    memory = '8 GB'
    time = '1h'

    withLabel: 'local' {
        executor = 'local'
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-genomesDB-STEP_4'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Create final species set for downstream subprojects'
    version = '1.1.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

report {
    enabled = false
}

timeline {
    enabled = false
}

dag {
    enabled = false
}
