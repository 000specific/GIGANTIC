/*
 * GIGANTIC Source Data Ingestion Pipeline - NextFlow Configuration
 * AI: Claude Code | Opus 4.5 / Opus 4.7 | 2026 February 13 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (nested keys preserved).
 *
 * Pattern: A (Sequential) - executor = 'local'
 * All processes run sequentially within a single job.
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested).

params {
    project {
        name = 'my_project'
        source_manifest = 'INPUT_user/source_manifest.tsv'
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    ingestion {
        overwrite_existing = false
        missing_file_action = 'error'
    }
}

// ============================================================================
// EXECUTOR - Pattern A (Sequential/Local)
// ============================================================================

executor {
    name = 'local'
    cpus = 1
    memory = '4 GB'
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources (lightweight for this pipeline - just copying files)
    cpus = 1
    memory = '2 GB'
    time = '1h'
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-Ingest-Source-Data'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Ingest user-provided source data (proteomes, genomes, GFFs) into GIGANTIC structure'
    version = '2.1.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS (optional - uncomment to enable)
// ============================================================================

// timeline {
//     enabled = true
//     file = "${params.output.base_dir}/nextflow_timeline.html"
// }
//
// report {
//     enabled = true
//     file = "${params.output.base_dir}/nextflow_report.html"
// }
