/*
 * ==============================================================================
 * NEXTFLOW CONFIGURATION - parsimony_tree_structures BLOCK_ocl_orthogroups
 * ==============================================================================
 * AI: Claude Code | Opus 4.7 | 2026 May 11
 * Human: Eric Edsinger
 *
 *  Values that users normally adjust for a specific run live in
 *  `START_HERE-user_config.yaml`, NOT here. `RUN-workflow.sh` reads them and
 *  injects them via `nextflow run --KEY value` so they become `params.KEY`
 *  below.
 *
 *  Currently plumbed through from config.yaml:
 *    slurm_account, slurm_qos, cpus, memory_gb
 *
 * ==============================================================================
 */

nextflow.enable.dsl = 2

manifest {
    name = 'GIGANTIC_parsimony_tree_structures_BLOCK_ocl_orthogroups'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Rank species tree structures by parsimony scores derived from orthogroup OCL data'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// PARAMETERS
// ============================================================================

params {
    config = "${baseDir}/../START_HERE-user_config.yaml"

    // SLURM configuration -- DO NOT hardcode real values here.
    // RUN-workflow.sh injects from START_HERE-user_config.yaml.
    slurm_account = ''
    slurm_qos = ''

    // Local-executor concurrency
    cpus = 2
    memory_gb = 8
}

// ============================================================================
// EXECUTOR DEFAULTS
// ============================================================================

process {
    cpus = 1
    memory = '4 GB'
    time = '2h'

    clusterOptions = "--account=${params.slurm_account} --qos=${params.slurm_qos}"

    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0

    withName: validate_inputs {
        cpus = 1
        memory = '4 GB'
        time = '1h'
    }
    withName: aggregate_ocl_per_structure {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }
    withName: compute_parsimony_scores {
        cpus = 1
        memory = '4 GB'
        time = '1h'
    }
    withName: bootstrap_ranking_confidence {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }
    withName: rank_structures_and_summarize {
        cpus = 1
        memory = '4 GB'
        time = '1h'
    }
    withName: visualize_ranking {
        cpus = 1
        memory = '4 GB'
        time = '1h'
    }
    withName: diagnose_criteria_divergence {
        cpus = 1
        memory = '8 GB'
        time = '30m'
    }
    withName: clade_binarized_parsimony {
        cpus = 2
        memory = '16 GB'
        time = '1h'
    }
    withName: clade_binarized_parsimony_subsampled {
        cpus = 2
        memory = '16 GB'
        time = '1h'
    }
    withName: write_run_log {
        cpus = 1
        memory = '2 GB'
        time = '15m'
    }
}

// ============================================================================
// REPORT AND TRACE OPTIONS
// ============================================================================

report {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_timeline.html"
    overwrite = true
}

trace {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_trace.txt"
    overwrite = true
    fields = 'task_id,hash,native_id,name,status,exit,submit,duration,realtime,%cpu,peak_rss,peak_vmem'
}

dag {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_dag.html"
    overwrite = true
}

// ============================================================================
// PROFILES
// ============================================================================

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        executor {
            name = 'slurm'
            queueSize = 20
            submitRateLimit = '10/1min'
            pollInterval = '30 sec'
        }
    }

    local {
        process {
            executor = 'local'
            cpus = 1
            memory = '4 GB'
        }
        executor {
            name = 'local'
            cpus = params.cpus as Integer
            memory = "${params.memory_gb} GB"
        }
    }
}

cleanup = false
