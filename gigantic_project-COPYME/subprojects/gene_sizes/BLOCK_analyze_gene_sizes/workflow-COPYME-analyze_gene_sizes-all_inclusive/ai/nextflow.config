/*
 * GIGANTIC gene_sizes - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 March 04
 * Human: Eric Edsinger
 *
 * Updated 2026-05-04 to mirror the working trees_gene_groups pattern:
 * use `new File()` wrapped in a function (NextFlow's `file()` is not
 * available at top-level config scope; older COPYME pattern used it
 * directly and failed under NF 25+ strict parsing).
 */

import org.yaml.snakeyaml.Yaml

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================
def loadConfig() {
    // projectDir = ai/ directory (where main.nf lives)
    // Config YAML is one level up at workflow root: projectDir/../START_HERE-user_config.yaml
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// PARAMETERS FROM USER CONFIG
// ============================================================================
params.input_user_dir = userConfig?.inputs?.input_user_dir ?: "INPUT_user"
params.gigantic_species_list = userConfig?.inputs?.gigantic_species_list ?: ""
params.proteome_dir = userConfig?.inputs?.proteome_dir ?: ""
params.output_dir = userConfig?.output?.base_dir ?: "OUTPUT_pipeline"
params.project_name = userConfig?.project_name ?: ""
params.resume = userConfig?.resume ?: false

// ============================================================================
// PROCESS CONFIGURATION
// ============================================================================
process {
    executor = 'local'
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0
}

// ============================================================================
// NEXTFLOW SETTINGS
// ============================================================================
nextflow {
    clean = true
}
