/*
 * GIGANTIC gene_sizes - NextFlow Configuration (Tier 1, all_inclusive)
 * AI: Claude Code | Opus 4.6 / Opus 4.7 | 2026 March 04 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (nested keys preserved).
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape:
//   inputs.{input_user_dir, gigantic_species_list, proteome_dir} (nested)
//   output.base_dir                                              (nested)
//   project_name, resume                                         (flat top-level)

params {
    inputs {
        input_user_dir = 'INPUT_user'
        gigantic_species_list = 'INPUT_user/gigantic_species_list.txt'
        proteome_dir = ''
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    project_name = ''
    resume = false
}

// ============================================================================
// PROCESS CONFIGURATION
// ============================================================================
process {
    executor = 'local'
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0
}

// ============================================================================
// NEXTFLOW SETTINGS
// ============================================================================
nextflow {
    clean = true
}
