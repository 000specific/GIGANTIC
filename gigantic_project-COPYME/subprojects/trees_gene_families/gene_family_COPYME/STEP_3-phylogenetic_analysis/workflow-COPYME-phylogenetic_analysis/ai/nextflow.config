// AI: Claude Code | Opus 4.6 | 2026 March 10 | Purpose: NextFlow configuration for STEP_3 phylogenetic analysis
// Human: Eric Edsinger

// ============================================================================
// STEP_3 Phylogenetic Analysis - NextFlow Configuration
// ============================================================================

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// Read resources from user config (flat keys)
def resourceCpus = userConfig?.cpus ?: 100
def resourceMemory = "${userConfig?.memory_gb ?: 700} GB"
def resourceTime = "${userConfig?.time_hours ?: 100}h"

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = resourceCpus
    memory = resourceMemory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = 0

    // Default resources for local processes
    withLabel: 'local' {
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }

    // MAFFT alignment (resource-intensive)
    withLabel: 'mafft' {
        cpus = resourceCpus
        memory = resourceMemory
        time = resourceTime
    }

    // ClipKit trimming
    withLabel: 'clipkit' {
        cpus = 4
        memory = '16 GB'
        time = '4h'
    }

    // FastTree (relatively fast)
    withLabel: 'fasttree' {
        cpus = 4
        memory = '16 GB'
        time = '4h'
    }

    // IQ-TREE (very resource-intensive)
    withLabel: 'iqtree' {
        cpus = resourceCpus
        memory = resourceMemory
        time = resourceTime
    }

    // VeryFastTree (parallelized FastTree - moderate resources)
    withLabel: 'veryfasttree' {
        cpus = 4
        memory = '16 GB'
        time = '4h'
    }

    // PhyloBayes (very slow, moderate memory, long runtime)
    withLabel: 'phylobayes' {
        cpus = 4
        memory = '32 GB'
        time = '336h'
    }

    // Visualization
    withLabel: 'visualization' {
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }
}

// Reporting
timeline {
    enabled = true
    file = "${projectDir}/../../OUTPUT_pipeline/phylogenetic_analysis_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${projectDir}/../../OUTPUT_pipeline/phylogenetic_analysis_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${projectDir}/../../OUTPUT_pipeline/phylogenetic_analysis_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${projectDir}/../../OUTPUT_pipeline/phylogenetic_analysis_dag.svg"
    overwrite = true
}

// Manifest
manifest {
    name = 'GIGANTIC STEP_3 Phylogenetic Analysis'
    author = 'Eric Edsinger (with AI: Claude Code | Opus 4.6)'
    description = 'Phylogenetic analysis with configurable tree-building methods'
    mainScript = 'main.nf'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}
