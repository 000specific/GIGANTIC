/*
 * GIGANTIC trees_gene_families STEP_1 - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 March 10
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from config.yaml and sets up NextFlow internals.
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    // projectDir = ai/ directory (where main.nf lives)
    // Config YAML is one level up at workflow root: projectDir/../START_HERE-user_config.yaml
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// Read resources from user config (flat keys)
def resourceCpus = userConfig?.cpus ?: 50
def resourceMemory = "${userConfig?.memory_gb ?: 187} GB"
def resourceTime = "${userConfig?.time_hours ?: 96}h"

// Resolve relative paths to absolute (needed for NextFlow work directories)
// Config paths are relative to workflow root (projectDir/..)
def workflowRoot = new File("${projectDir}/..").canonicalPath
def resolveConfigPath = { String relPath ->
    if (relPath == null) return null
    def resolved = new File("${workflowRoot}/${relPath}").canonicalPath
    return resolved
}

// ============================================================================
// PARAMETERS (from START_HERE-user_config.yaml)
// ============================================================================

params {
    // Gene family (single gene family per workflow copy)
    gene_family = userConfig?.gene_family?.name ?: null

    // RGS files
    rgs_full_length_file = userConfig?.gene_family?.rgs_full_length_file ?: null
    rgs_subsequence_file = userConfig?.gene_family?.rgs_subsequence_file ?: null

    // RGS sequence type: true = full-length proteins (default)
    //                     false = domain-only sequences (e.g., pore regions)
    // When true:  rgs_full_length_file is used for BLAST discovery
    // When false: rgs_subsequence_file is used for BLAST discovery,
    //             rgs_full_length_file is used by Script 018 for AGS restoration
    rgs_sequence_is_full_length = userConfig?.gene_family?.rgs_sequence_is_full_length != null ? userConfig.gene_family.rgs_sequence_is_full_length : true

    // Orphan RGS: include RGS seeds whose source species has no genome in the set
    // as reciprocal BLAST targets (appended to modified genomes by Script 009)
    include_orphan_rgs = userConfig?.gene_family?.include_orphan_rgs ?: false

    // Derived: the file actually used for BLAST homolog discovery
    // (NextFlow cannot reference params from within params{}, so compute directly from userConfig)
    rgs_file = (userConfig?.gene_family?.rgs_sequence_is_full_length != null ? userConfig.gene_family.rgs_sequence_is_full_length : true) ? (userConfig?.gene_family?.rgs_full_length_file ?: null) : (userConfig?.gene_family?.rgs_subsequence_file ?: null)

    // User input files
    species_keeper_list = userConfig?.inputs?.species_keeper_list ?: "INPUT_user/species_keeper_list.tsv"
    rgs_species_map = userConfig?.inputs?.rgs_species_map ?: "INPUT_user/rgs_species_map.tsv"

    // BLAST database paths - resolved to absolute for NextFlow work directory compatibility
    // User sets relative paths in START_HERE-user_config.yaml, resolved here
    blast_databases_dir = resolveConfigPath(userConfig?.inputs?.blast_databases_dir)
    rgs_genomes_dir = resolveConfigPath(userConfig?.inputs?.rgs_genomes_dir)

    // Project settings
    project_database = userConfig?.project?.database ?: "speciesN_T1-speciesN"
    project_name = userConfig?.project?.name ?: "GIGANTIC"

    // BLAST parameters
    blast_evalue = userConfig?.blast?.evalue ?: "1e-3"
    blast_threads = userConfig?.blast?.threads ?: 50
    blast_conda_env = userConfig?.blast?.conda_env ?: "blast"

    // Output
    output_dir = userConfig?.output?.base_dir ?: "OUTPUT_pipeline"
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = resourceCpus
    memory = resourceMemory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources
    cpus = 4
    memory = '16 GB'
    time = '6h'

    // Label-specific resources
    withLabel: 'local' {
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }

    withLabel: 'blast' {
        cpus = resourceCpus
        memory = resourceMemory
        time = resourceTime
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-trees_gene_families-STEP_1'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'RBH/RBF homolog discovery via reciprocal BLAST'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}
