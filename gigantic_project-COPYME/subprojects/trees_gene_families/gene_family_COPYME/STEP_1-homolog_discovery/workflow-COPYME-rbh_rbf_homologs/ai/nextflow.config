/*
 * GIGANTIC trees_gene_families STEP_1 - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 / Opus 4.7 | 2026 March 10 / patched 2026 May 25
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml directly via -params-file. NextFlow loads
 * it natively; params.X.Y.Z here mirror the yaml shape (nested keys preserved).
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - No top-level `def` declarations mixed with config blocks.
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested + flat).

params {
    gene_family {
        name = null
        rgs_full_length_file = null
        rgs_subsequence_file = null
        rgs_sequence_is_full_length = true
        include_orphan_rgs = false
    }
    inputs {
        species_keeper_list = 'INPUT_user/species_keeper_list.tsv'
        rgs_species_map = 'INPUT_user/rgs_species_map.tsv'
        blast_databases_dir = null
        rgs_genomes_dir = null
    }
    project {
        name = 'GIGANTIC'
        database = 'speciesN_T1-speciesN'
    }
    blast {
        evalue = '1e-3'
        threads = 50
        conda_env = 'blast'
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    cpus = 50
    memory_gb = 187
    time_hours = 96
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.cpus
    memory = "${params.memory_gb} GB"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources
    cpus = 4
    memory = '16 GB'
    time = '6h'

    // Label-specific resources
    withLabel: 'local' {
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }

    withLabel: 'blast' {
        cpus = params.cpus
        memory = "${params.memory_gb} GB"
        time = "${params.time_hours}h"
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-trees_gene_families-STEP_1'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'RBH/RBF homolog discovery via reciprocal BLAST'
    version = '1.1.0'
    nextflowVersion = '>=21.04.0'
}
