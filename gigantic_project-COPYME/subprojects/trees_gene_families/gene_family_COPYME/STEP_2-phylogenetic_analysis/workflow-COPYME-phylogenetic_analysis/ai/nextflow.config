// AI: Claude Code | Opus 4.6 / Opus 4.7 | 2026 March 10 / patched 2026 May 25
// Human: Eric Edsinger

// ============================================================================
// STEP_2 Phylogenetic Analysis - NextFlow Configuration
// ============================================================================
// Per-tool conda environments and resource allocations.
// NextFlow manages SLURM resources per-process via labels.
//
// NextFlow 26.x compatibility:
//   - No `import org.yaml.snakeyaml.Yaml` at top-level.
//   - No top-level `def` declarations mixed with config blocks.
//   - RUN-workflow.sh passes the yaml directly via -params-file.
// ============================================================================

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested).

params {
    resources {
        mafft        { cpus = 50; memory_gb = 350; time_hours = 168 }
        clipkit      { cpus = 4;  memory_gb = 16;  time_hours = 4   }
        fasttree     { cpus = 4;  memory_gb = 16;  time_hours = 4   }
        iqtree       { cpus = 50; memory_gb = 350; time_hours = 168 }
        veryfasttree { cpus = 4;  memory_gb = 16;  time_hours = 4   }
        phylobayes   { cpus = 4;  memory_gb = 32;  time_hours = 336 }
    }
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.resources.mafft.cpus > params.resources.iqtree.cpus ? params.resources.mafft.cpus : params.resources.iqtree.cpus
    memory = "${params.resources.mafft.memory_gb} GB"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = 0

    // Default resources for local processes (prepare input, clean sequences)
    withLabel: 'local' {
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }

    // MAFFT alignment (resource-intensive)
    withLabel: 'mafft' {
        conda = 'ai_gigantic_mafft'
        cpus = params.resources.mafft.cpus
        memory = "${params.resources.mafft.memory_gb} GB"
        time = "${params.resources.mafft.time_hours}h"
    }

    // ClipKit trimming
    withLabel: 'clipkit' {
        conda = 'ai_gigantic_clipkit'
        cpus = params.resources.clipkit.cpus
        memory = "${params.resources.clipkit.memory_gb} GB"
        time = "${params.resources.clipkit.time_hours}h"
    }

    // FastTree (relatively fast)
    withLabel: 'fasttree' {
        conda = 'ai_gigantic_fasttree'
        cpus = params.resources.fasttree.cpus
        memory = "${params.resources.fasttree.memory_gb} GB"
        time = "${params.resources.fasttree.time_hours}h"
    }

    // IQ-TREE (very resource-intensive)
    withLabel: 'iqtree' {
        conda = 'ai_gigantic_iqtree'
        cpus = params.resources.iqtree.cpus
        memory = "${params.resources.iqtree.memory_gb} GB"
        time = "${params.resources.iqtree.time_hours}h"
    }

    // VeryFastTree (parallelized FastTree - moderate resources)
    withLabel: 'veryfasttree' {
        conda = 'ai_gigantic_veryfasttree'
        cpus = params.resources.veryfasttree.cpus
        memory = "${params.resources.veryfasttree.memory_gb} GB"
        time = "${params.resources.veryfasttree.time_hours}h"
    }

    // PhyloBayes (very slow, moderate memory, long runtime)
    withLabel: 'phylobayes' {
        conda = 'ai_gigantic_phylobayes'
        cpus = params.resources.phylobayes.cpus
        memory = "${params.resources.phylobayes.memory_gb} GB"
        time = "${params.resources.phylobayes.time_hours}h"
    }

    // Visualization is handled by STEP_3-tree_visualization, not here.
}

// Reporting
timeline {
    enabled = true
    file = "${projectDir}/../OUTPUT_pipeline/phylogenetic_analysis_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${projectDir}/../OUTPUT_pipeline/phylogenetic_analysis_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${projectDir}/../OUTPUT_pipeline/phylogenetic_analysis_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${projectDir}/../OUTPUT_pipeline/phylogenetic_analysis_dag.svg"
    overwrite = true
}

// Manifest
manifest {
    name = 'GIGANTIC STEP_2 Phylogenetic Analysis'
    author = 'Eric Edsinger (with AI: Claude Code | Opus 4.6 / Opus 4.7)'
    description = 'Phylogenetic analysis with configurable tree-building methods'
    mainScript = 'main.nf'
    version = '1.1.0'
    nextflowVersion = '>=21.04.0'
}
