// AI: Claude Code | Opus 4.6 | 2026 March 10 | Purpose: NextFlow configuration for STEP_1 RGS validation
// Human: Eric Edsinger

// ============================================================================
// STEP_1 RGS Validation - NextFlow Configuration
// ============================================================================

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// Read resources from user config (flat keys)
def resourceCpus = userConfig?.cpus ?: 1
def resourceMemory = "${userConfig?.memory_gb ?: 4} GB"
def resourceTime = "${userConfig?.time_hours ?: 1}h"

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = resourceCpus
    memory = resourceMemory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = 0

    withLabel: 'local' {
        cpus = resourceCpus
        memory = resourceMemory
        time = resourceTime
    }
}

// Reporting
timeline {
    enabled = true
    file = "${projectDir}/../../OUTPUT_pipeline/rgs_validation_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${projectDir}/../../OUTPUT_pipeline/rgs_validation_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${projectDir}/../../OUTPUT_pipeline/rgs_validation_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${projectDir}/../../OUTPUT_pipeline/rgs_validation_dag.svg"
    overwrite = true
}

// Manifest
manifest {
    name = 'GIGANTIC STEP_1 RGS Validation'
    author = 'Eric Edsinger (with AI: Claude Code | Opus 4.6)'
    description = 'Validate and prepare Reference Gene Set files'
    mainScript = 'main.nf'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}
