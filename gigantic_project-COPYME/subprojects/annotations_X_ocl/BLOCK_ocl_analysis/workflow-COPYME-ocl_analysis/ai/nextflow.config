/*
 * ==============================================================================
 * NEXTFLOW CONFIGURATION - GIGANTIC ANNOTATIONS OCL PIPELINE
 * ==============================================================================
 * AI: Claude Code | Opus 4.6 | 2026 March 04
 * Human: Eric Edsinger
 * ==============================================================================
 * Configuration for running the annotations OCL (Origin-Conservation-Loss)
 * pipeline on HiPerGator SLURM cluster.
 *
 * Resource allocations based on operational experience with the orthogroups_X_ocl
 * pipeline. Annotations OCL has similar compute requirements since it operates
 * on the same tree structures with comparable numbers of groups.
 * ==============================================================================
 */

// ============================================================================
// GENERAL SETTINGS
// ============================================================================

// Enable DSL2 syntax
nextflow.enable.dsl = 2

// Workflow metadata
manifest {
    name = 'GIGANTIC_Annotations_OCL_Pipeline'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Origin-Conservation-Loss analysis of annotation groups across phylogenetic tree structures'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// PARAMETERS
// ============================================================================

params {
    // Configuration file (relative to ai/ directory)
    config = "${baseDir}/../START_HERE-user_config.yaml"

    // Structure manifest (overrides config if provided)
    structure_manifest = null

    // Output directory (overrides config if provided)
    output_dir = null

    // SLURM configuration (override at command line)
    slurm_account = 'moroz'
    slurm_qos = 'moroz-b'
}

// ============================================================================
// EXECUTOR CONFIGURATION - HIPERGATOR SLURM
// ============================================================================

executor {
    name = 'slurm'
    queueSize = 50              // Maximum number of jobs to submit at once
    submitRateLimit = '10/1min' // Submit max 10 jobs per minute
    pollInterval = '30 sec'     // Check job status every 30 seconds
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    // Default executor
    executor = 'slurm'

    // Default resource allocations
    cpus = 1
    memory = '4 GB'
    time = '24h'

    // SLURM-specific settings
    clusterOptions = "--account=${params.slurm_account} --qos=${params.slurm_qos}"

    // Error handling - strict fail-fast for research pipelines
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0  // Stop immediately on first failure

    // ========================================================================
    // PROCESS-SPECIFIC RESOURCE REQUIREMENTS
    // ========================================================================

    // Script 001: Create annogroups (loads annotation files for all species)
    withName: create_annogroups {
        cpus = 2
        memory = '14 GB'
        time = '24h'
        maxForks = 20  // Limit concurrent structures to prevent NFS I/O storm
    }

    // Script 002: Determine origins (moderate compute - MRCA algorithm)
    withName: determine_origins {
        cpus = 1
        memory = '4 GB'
        time = '24h'
    }

    // Script 003: Quantify conservation/loss (moderate compute - TEMPLATE_03)
    withName: quantify_conservation_loss {
        cpus = 1
        memory = '4 GB'
        time = '24h'
    }

    // Script 004: Comprehensive analysis (heavier compute - integration)
    withName: comprehensive_ocl_analysis {
        cpus = 1
        memory = '8 GB'
        time = '24h'
    }

    // Script 005: Validation (lightweight - data verification only)
    withName: validate_results {
        cpus = 1
        memory = '4 GB'
        time = '24h'
    }
}

// ============================================================================
// REPORT AND TRACE OPTIONS
// ============================================================================

// Generate execution report
report {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_report.html"
    overwrite = true
}

// Generate execution timeline
timeline {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_timeline.html"
    overwrite = true
}

// Generate execution trace
trace {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_trace.txt"
    overwrite = true
    fields = 'task_id,hash,native_id,name,status,exit,submit,duration,realtime,%cpu,peak_rss,peak_vmem'
}

// Generate execution DAG (directed acyclic graph)
dag {
    enabled = true
    file = "OUTPUT_pipeline/pipeline_dag.html"
    overwrite = true
}

// ============================================================================
// PROFILES
// ============================================================================

profiles {
    // HiPerGator SLURM (default)
    hipergator {
        process.executor = 'slurm'
    }

    // Standard profile
    standard {
        process.executor = 'slurm'
    }

    // Local execution (for testing with single structure)
    local {
        process {
            executor = 'local'
            cpus = 1
            memory = '8 GB'
        }
        executor {
            name = 'local'
            cpus = 4
            memory = '16 GB'
        }
    }

    // Test profile (single structure, local execution)
    test {
        process {
            executor = 'local'
            cpus = 1
            memory = '8 GB'
        }
    }
}

// ============================================================================
// CLEANUP OPTIONS
// ============================================================================

// Do not auto-delete work directory (keep for debugging)
cleanup = false
