// AI: Claude Code | Opus 4.6 | 2026 March 03 | Purpose: Nextflow configuration for TMbed transmembrane topology prediction pipeline
// Human: Eric Edsinger

// TMbed Transmembrane Topology Prediction Pipeline Configuration
// Runs TMbed transmembrane topology prediction on each species proteome from a manifest

params {
    // Input: proteome manifest TSV from INPUT_user/
    proteome_manifest = 'INPUT_user/proteome_manifest.tsv'

    // Input: directory containing proteome FASTA files
    proteomes_dir = '../../genomesDB/STEP_2-standardize_and_evaluate/output_to_input/gigantic_proteomes'

    // Pipeline output
    output_dir = 'OUTPUT_pipeline'

    // Number of sequences per prediction batch (1 is safest for GPU memory)
    batch_size = 1

    // Use GPU acceleration when available
    use_gpu = true

    // Fall back to CPU if GPU is unavailable
    cpu_fallback = true

    // Conda environment with TMbed installed
    conda_environment = 'ai_gigantic_tmbed'
}

process {
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0

    withName: 'validate_proteome_manifest' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'run_tmbed' {
        cpus = 4
        memory = '32 GB'
        time = '12h'
    }
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
}
