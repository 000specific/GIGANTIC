// AI: Claude Code | Opus 4.6 | 2026 March 03 | Purpose: Nextflow configuration for InterProScan protein domain and function annotation pipeline
// Human: Eric Edsinger

// InterProScan Protein Domain and Function Annotation Pipeline Configuration
// Runs InterProScan on chunked proteomes for parallel processing, then combines results per species

params {
    // Input: proteome manifest TSV from INPUT_user/
    proteome_manifest = 'INPUT_user/proteome_manifest.tsv'

    // Input: directory containing proteome FASTA files
    proteomes_dir = '../../genomesDB/STEP_2-standardize_and_evaluate/output_to_input/gigantic_proteomes'

    // Pipeline output
    output_dir = 'OUTPUT_pipeline'

    // InterProScan installation path (user must set this)
    interproscan_install_path = '/path/to/interproscan'

    // Number of sequences per chunk for parallel InterProScan execution
    // Larger chunks = fewer jobs but longer per-job runtime
    // Smaller chunks = more parallelism but more job overhead
    chunk_size = 1000

    // CPUs allocated to each InterProScan job
    cpus_per_job = 16

    // InterProScan applications to run (comma-separated or 'all' for all databases)
    // Examples: 'Pfam,Gene3D,SUPERFAMILY' or 'all'
    applications = 'all'

    // Conda environment with InterProScan installed
    conda_environment = 'ai_gigantic_interproscan'
}

process {
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0

    withName: 'validate_proteome_manifest' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'chunk_proteomes' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'run_interproscan' {
        cpus = 16
        memory = '64 GB'
        time = '24h'
    }

    withName: 'combine_interproscan_results' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
}
