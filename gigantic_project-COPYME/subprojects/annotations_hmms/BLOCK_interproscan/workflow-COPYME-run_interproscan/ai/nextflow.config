/*
 * InterProScan Protein Domain Annotation Pipeline - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 / Opus 4.7 | 2026 March 13 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh flattens the YAML into .params.json and passes it to
 * NextFlow via `-params-file .params.json`. All values from the YAML become
 * `params.KEY` here through that mechanism. This file only defines DEFAULTS
 * (used if the orchestrator doesn't override).
 *
 * Supports three execution modes:
 *   - "local":       All processes run locally (sequential)
 *   - "slurm":       All processes run inside one SLURM job (sequential)
 *   - "slurm_burst": InterProScan chunks submitted as individual SLURM burst jobs (parallel)
 *
 * Conda environment: ai_gigantic_interproscan (activated by RUN-workflow.sh)
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level (rejected by 26.x parser).
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 */

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================

params {
    // Structural params (not user-configurable - part of workflow architecture)
    proteome_manifest = "${projectDir}/../INPUT_user/proteome_manifest.tsv"
    output_dir = 'OUTPUT_pipeline'

    // User-configurable params (sourced from START_HERE-user_config.yaml via .params.json)
    project_name = 'my_project'
    interproscan_install_path = '/path/to/interproscan'
    chunk_size = 1000
    applications = 'all'

    // Execution mode (local | slurm | slurm_burst)
    execution_mode = 'local'

    // Resources for local/slurm modes (single job, sequential)
    cpus       = 25
    memory_gb  = 187
    time_hours = 96

    // Resources for slurm_burst mode (per-chunk SLURM jobs)
    burst_cpus_per_chunk       = 4
    burst_memory_gb_per_chunk  = 16
    burst_time_hours_per_chunk = 4
    burst_qos                  = ''
    slurm_account              = ''
}

// ============================================================================
// EXECUTION MODE DETECTION (derived from params)
// ============================================================================

def isBurstMode = ( params.execution_mode == 'slurm_burst' )

// ============================================================================
// RESOURCES - derived from params
// ============================================================================

// Resources for local/slurm modes (single job, sequential)
def resourceCpus   = params.cpus
def resourceMemory = "${params.memory_gb} GB"
def resourceTime   = "${params.time_hours}h"

// Resources for burst mode (per-chunk SLURM jobs)
def burstCpus    = params.burst_cpus_per_chunk
def burstMemory  = "${params.burst_memory_gb_per_chunk} GB"
def burstTime    = "${params.burst_time_hours_per_chunk}h"
def burstQos     = params.burst_qos
def burstAccount = params.slurm_account

// ============================================================================
// EXECUTOR
// ============================================================================

if ( isBurstMode ) {
    // Burst mode: Nextflow orchestrates, submitting chunk jobs to SLURM
    // The executor block sets defaults; run_interproscan overrides to 'slurm'
    executor {
        name = 'local'
        cpus = 4
        memory = '8 GB'
    }
} else {
    // Local/SLURM modes: everything runs within the current environment
    executor {
        name   = 'local'
        cpus   = resourceCpus
        memory = resourceMemory
    }
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    // Default: all processes run locally (lightweight steps always local)
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources (lightweight processes)
    cpus = 1
    memory = '4 GB'
    time = '2h'

    withName: 'validate_proteome_manifest' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'chunk_proteomes' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'run_interproscan' {
        if ( isBurstMode ) {
            // Burst mode: each chunk is its own SLURM job
            executor = 'slurm'
            clusterOptions = "--account=${burstAccount} --qos=${burstQos}"
            cpus = burstCpus
            memory = burstMemory
            time = burstTime
            // Burst QOS jobs can be preempted by higher-priority jobs.
            // Retry preempted chunks automatically instead of killing the pipeline.
            errorStrategy = { task.exitStatus in [143, 140] ? 'retry' : 'terminate' }
            maxRetries = 3
        } else {
            // Local/SLURM: runs within existing allocation
            cpus = resourceCpus
            memory = resourceMemory
            time = resourceTime
        }
    }

    withName: 'combine_interproscan_results' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-InterProScan'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'InterProScan protein domain and function annotation on species proteomes'
    version = '1.1.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS (optional - uncomment to enable)
// ============================================================================

// timeline {
//     enabled = true
//     file = "${params.output_dir}/nextflow_timeline.html"
// }
//
// report {
//     enabled = true
//     file = "${params.output_dir}/nextflow_report.html"
// }
