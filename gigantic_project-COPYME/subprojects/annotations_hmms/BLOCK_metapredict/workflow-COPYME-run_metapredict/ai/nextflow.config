// AI: Claude Code | Opus 4.6 | 2026 March 03 | Purpose: Nextflow configuration for MetaPredict disorder prediction pipeline
// Human: Eric Edsinger

// MetaPredict Disorder Prediction Pipeline Configuration
// Runs MetaPredict disorder prediction on each species proteome from a manifest

params {
    // Input: proteome manifest TSV from INPUT_user/
    proteome_manifest = 'INPUT_user/proteome_manifest.tsv'

    // Input: directory containing proteome FASTA files
    proteomes_dir = '../../genomesDB/STEP_2-standardize_and_evaluate/output_to_input/gigantic_proteomes'

    // Pipeline output
    output_dir = 'OUTPUT_pipeline'

    // MetaPredict prediction types (comma-separated: disorder,idrs,plddt)
    prediction_types = 'disorder,idrs'

    // Conda environment with metapredict installed
    conda_environment = 'ai_gigantic_annotations'
}

process {
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0

    withName: 'validate_proteome_manifest' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'run_metapredict' {
        cpus = 2
        memory = '8 GB'
        time = '4h'
    }
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
}
