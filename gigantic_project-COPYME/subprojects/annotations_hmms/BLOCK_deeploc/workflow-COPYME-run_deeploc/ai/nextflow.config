/*
 * DeepLoc Subcellular Localization Prediction Pipeline - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 March 10
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from START_HERE-user_config.yaml and sets up NextFlow internals.
 *
 * Pattern: A (Sequential) - executor = 'local'
 * All processes run sequentially within a single job.
 *
 * Conda environment: ai_gigantic_deeploc (activated by RUN-workflow.sh)
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// PARAMETERS (from START_HERE-user_config.yaml)
// ============================================================================

params {
    // Structural params (not user-configurable - part of workflow architecture)
    proteome_manifest = "${projectDir}/../INPUT_user/proteome_manifest.tsv"
    output_dir = 'OUTPUT_pipeline'

    // User-configurable params (from START_HERE-user_config.yaml)
    project_name = userConfig?.project_name ?: 'my_project'
    model_type = userConfig?.model_type ?: 'Accurate'
}

// ============================================================================
// RESOURCES (from START_HERE-user_config.yaml)
// ============================================================================

def resourceCpus = userConfig?.cpus ?: 4
def resourceMemory = "${userConfig?.memory_gb ?: 32} GB"
def resourceTime = "${userConfig?.time_hours ?: 12}h"

// ============================================================================
// EXECUTOR - Pattern A (Sequential/Local)
// ============================================================================

executor {
    name = 'local'
    cpus = resourceCpus
    memory = resourceMemory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources (lightweight processes)
    cpus = 1
    memory = '4 GB'
    time = '2h'

    withName: 'validate_proteome_manifest' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'run_deeploc' {
        cpus = resourceCpus
        memory = resourceMemory
        time = resourceTime
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-DeepLoc'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'DeepLoc subcellular localization prediction on species proteomes'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS (optional - uncomment to enable)
// ============================================================================

// timeline {
//     enabled = true
//     file = "${params.output_dir}/nextflow_timeline.html"
// }
//
// report {
//     enabled = true
//     file = "${params.output_dir}/nextflow_report.html"
// }
