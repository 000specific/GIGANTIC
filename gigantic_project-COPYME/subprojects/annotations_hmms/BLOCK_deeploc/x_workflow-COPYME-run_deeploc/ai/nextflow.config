// AI: Claude Code | Opus 4.6 | 2026 March 03 | Purpose: Nextflow configuration for DeepLoc subcellular localization prediction pipeline
// Human: Eric Edsinger

// DeepLoc Subcellular Localization Prediction Pipeline Configuration
// Runs DeepLoc 2.1 subcellular localization prediction on each species proteome from a manifest

params {
    // Input: proteome manifest TSV from INPUT_user/
    proteome_manifest = 'INPUT_user/proteome_manifest.tsv'

    // Input: directory containing proteome FASTA files
    proteomes_dir = '../../../genomesDB-species70/output_to_input/STEP_4-create_final_species_set/species70_gigantic_T1_proteomes'

    // Pipeline output
    output_dir = 'OUTPUT_pipeline'

    // DeepLoc model type ("Accurate" for higher quality, "Fast" for speed)
    model_type = 'Accurate'

    // Conda environment with DeepLoc 2.1 installed
    conda_environment = 'ai_gigantic_deeploc'
}

process {
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0

    withName: 'validate_proteome_manifest' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'run_deeploc' {
        cpus = 4
        memory = '32 GB'
        time = '12h'
    }
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
}
