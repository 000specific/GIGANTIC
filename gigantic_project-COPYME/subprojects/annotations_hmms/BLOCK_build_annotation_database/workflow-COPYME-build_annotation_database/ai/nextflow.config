/*
 * Annotation Database Builder Pipeline - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 March 10
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from START_HERE-user_config.yaml and sets up NextFlow internals.
 *
 * Pattern: A (Sequential) - executor = 'local'
 * All processes run sequentially within a single job.
 *
 * Conda environment: ai_gigantic_annotations_hmms (activated by RUN-workflow.sh)
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// PARAMETERS (from START_HERE-user_config.yaml)
// ============================================================================

params {
    // Structural params (not user-configurable - part of workflow architecture)
    output_dir = 'OUTPUT_pipeline'

    // User-configurable params (from START_HERE-user_config.yaml)
    project_name = userConfig?.project_name ?: 'my_project'
    go_ontology_url = userConfig?.go_ontology_url ?: 'http://purl.obolibrary.org/obo/go/go-basic.obo'
    go_ontology_cache_days = userConfig?.go_ontology_cache_days ?: 30
    proteomes_dir = userConfig?.proteomes_dir ?: ''
}

// ============================================================================
// RESOURCES (from START_HERE-user_config.yaml)
// ============================================================================

def resourceCpus = userConfig?.cpus ?: 1
def resourceMemory = "${userConfig?.memory_gb ?: 16} GB"
def resourceTime = "${userConfig?.time_hours ?: 8}h"

// ============================================================================
// EXECUTOR - Pattern A (Sequential/Local)
// ============================================================================

executor {
    name = 'local'
    cpus = resourceCpus
    memory = resourceMemory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources (lightweight processes)
    cpus = 1
    memory = '4 GB'
    time = '2h'

    withName: 'discover_tool_outputs' {
        cpus = 1
        memory = '4 GB'
        time = '15m'
    }

    withName: 'download_go_ontology' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'parse_interproscan' {
        cpus = 1
        memory = '16 GB'
        time = '4h'
    }

    withName: 'parse_deeploc' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'parse_signalp' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'parse_tmbed' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'parse_metapredict' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'compile_annotation_statistics' {
        cpus = 1
        memory = '16 GB'
        time = '2h'
    }

    withName: 'analyze_cross_tool_consistency' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_annotation_quality' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_protein_complexity' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_functional_categories' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_domain_architecture' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'detect_annotation_outliers' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'generate_visualization_data' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_phylogenetic_patterns' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-AnnotationDatabaseBuilder'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Build unified annotation database from all annotation tool outputs'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS (optional - uncomment to enable)
// ============================================================================

// timeline {
//     enabled = true
//     file = "${params.output_dir}/nextflow_timeline.html"
// }
