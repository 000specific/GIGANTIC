// AI: Claude Code | Opus 4.6 | 2026 March 03 | Purpose: Nextflow configuration for annotation database builder pipeline
// Human: Eric Edsinger

// Annotation Database Builder Pipeline Configuration
// Parses tool outputs, builds standardized database, generates statistics and analyses

params {
    // Pipeline output
    output_dir = 'OUTPUT_pipeline'

    // GO Ontology download settings
    go_ontology_url = 'http://purl.obolibrary.org/obo/go/go-basic.obo'
    go_ontology_cache_days = 30

    // Species set name (for output file naming)
    // Replace SET_NAME_HERE with your species set name (e.g., species71)
    species_set_name = 'SET_NAME_HERE'

    // Proteomes directory for unannotated protein identification
    // Path relative to the workflow directory (parent of ai/)
    // Parsers 003-007 will add unannotated protein entries for proteins with zero annotations
    // Set to '' (empty string) to skip unannotated protein identification
    // Replace SET_NAME_HERE with your species set name (e.g., species71)
    proteomes_dir = '../../../../genomesDB/output_to_input/STEP_4-create_final_species_set/SET_NAME_HERE_gigantic_T1_proteomes'

    // Conda environment
    conda_environment = 'ai_gigantic_annotations_hmms'
}

process {
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0

    withName: 'discover_tool_outputs' {
        cpus = 1
        memory = '4 GB'
        time = '15m'
    }

    withName: 'download_go_ontology' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'parse_interproscan' {
        cpus = 1
        memory = '16 GB'
        time = '4h'
    }

    withName: 'parse_deeploc' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'parse_signalp' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'parse_tmbed' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'parse_metapredict' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'compile_annotation_statistics' {
        cpus = 1
        memory = '16 GB'
        time = '2h'
    }

    withName: 'analyze_cross_tool_consistency' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_annotation_quality' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_protein_complexity' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_functional_categories' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_domain_architecture' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'detect_annotation_outliers' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'generate_visualization_data' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_phylogenetic_patterns' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
}
