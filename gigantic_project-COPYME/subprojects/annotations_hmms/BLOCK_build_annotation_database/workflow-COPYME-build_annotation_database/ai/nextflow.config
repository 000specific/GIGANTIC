/*
 * Annotation Database Builder Pipeline - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 / Opus 4.7 | 2026 March 10 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh flattens the YAML into .params.json and passes it to
 * NextFlow via `-params-file .params.json`. All values from the YAML become
 * `params.KEY` here through that mechanism. This file only defines DEFAULTS
 * (used if the orchestrator doesn't override).
 *
 * Pattern: A (Sequential) - executor = 'local'
 * All processes run sequentially within a single job.
 *
 * Conda environment: aiG-annotations_hmms-build_annotation_database
 *                    (activated by RUN-workflow.sh)
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level (rejected by 26.x parser).
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 */

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================

params {
    // Structural params (not user-configurable - part of workflow architecture)
    output_dir = 'OUTPUT_pipeline'

    // User-configurable params (sourced from START_HERE-user_config.yaml via .params.json)
    project_name           = 'my_project'
    go_ontology_url        = 'http://purl.obolibrary.org/obo/go/go-basic.obo'
    go_ontology_cache_days = 30
    proteomes_dir          = ''

    // Resource params (also sourced from START_HERE-user_config.yaml)
    cpus       = 1
    memory_gb  = 16
    time_hours = 8
}

// ============================================================================
// RESOURCES - derived from params
// ============================================================================

def resourceCpus   = params.cpus
def resourceMemory = "${params.memory_gb} GB"
def resourceTime   = "${params.time_hours}h"

// ============================================================================
// EXECUTOR - Pattern A (Sequential/Local)
// ============================================================================

executor {
    name   = 'local'
    cpus   = resourceCpus
    memory = resourceMemory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources (lightweight processes)
    cpus = 1
    memory = '4 GB'
    time = '2h'

    withName: 'discover_tool_outputs' {
        cpus = 1
        memory = '4 GB'
        time = '15m'
    }

    withName: 'download_go_ontology' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'parse_interproscan' {
        cpus = 1
        memory = '16 GB'
        time = '4h'
    }

    withName: 'parse_deeploc' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'parse_signalp' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'parse_tmbed' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'parse_metapredict' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withName: 'compile_annotation_statistics' {
        cpus = 1
        memory = '16 GB'
        time = '2h'
    }

    withName: 'analyze_cross_tool_consistency' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_annotation_quality' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_protein_complexity' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_functional_categories' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_domain_architecture' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'detect_annotation_outliers' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'generate_visualization_data' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'analyze_phylogenetic_patterns' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-AnnotationDatabaseBuilder'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Build unified annotation database from all annotation tool outputs'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS (optional - uncomment to enable)
// ============================================================================

// timeline {
//     enabled = true
//     file = "${params.output_dir}/nextflow_timeline.html"
// }
//
// report {
//     enabled = true
//     file = "${params.output_dir}/nextflow_report.html"
// }
