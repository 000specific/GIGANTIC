// AI: Claude Code | Opus 4.6 | 2026 March 03 | Purpose: Nextflow configuration for SignalP signal peptide prediction pipeline
// Human: Eric Edsinger

// SignalP Signal Peptide Prediction Pipeline Configuration
// Runs SignalP 6 signal peptide prediction on each species proteome from a manifest

params {
    // Input: proteome manifest TSV from INPUT_user/
    proteome_manifest = 'INPUT_user/proteome_manifest.tsv'

    // Input: directory containing proteome FASTA files
    proteomes_dir = '../../genomesDB/STEP_2-standardize_and_evaluate/output_to_input/gigantic_proteomes'

    // Pipeline output
    output_dir = 'OUTPUT_pipeline'

    // Organism type for signal peptide prediction ("eukarya", "gram_positive", "gram_negative", "archaea")
    organism_type = 'eukarya'

    // Prediction mode ("slow" for higher accuracy, "fast" for speed)
    mode = 'slow'

    // Conda environment with SignalP 6 installed
    conda_environment = 'ai_gigantic_signalp'
}

process {
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0

    withName: 'validate_proteome_manifest' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'run_signalp' {
        cpus = 4
        memory = '16 GB'
        time = '12h'
    }
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
}
