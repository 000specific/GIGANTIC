/*
 * GIGANTIC hotspots - BLOCK_identify_hotspots NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 May 04
 * Human: Eric Edsinger
 *
 * Per-species hotspot computation is light (seconds per species). Default
 * execution_mode is "local"; SLURM mode is supported for very large species
 * sets but typically not needed at species70 scale.
 *
 * NextFlow 26+ strict config DSL is in effect: no top-level `def` / `import`
 * statements; values flow in via env vars (set by RUN-workflow.sh) and
 * -params-file (set by RUN-workflow.sh).
 */

// ============================================================================
// PARAMS — defaults; -params-file from RUN-workflow.sh overrides at runtime
// ============================================================================

params {
    // Inputs
    self_blast_reports_dir = '../../output_to_input/BLOCK_self_blast/self_blast_reports'
    gene_coordinates_dir   = '../../research_notebook/research_user/gene_coordinates'
    proteomes_dir          = '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/species70_gigantic_T1_proteomes'
    gigantic_species_list  = 'INPUT_user/gigantic_species_list.txt'

    // Output
    output_dir = 'OUTPUT_pipeline'

    // Hotspot parameters
    evalue_threshold      = '1e-60'
    window_size           = 20
    minimum_paralog_count = 2

    // Project metadata
    project_name      = 'GIGANTIC'
    conda_environment = 'ai_gigantic_hotspots'
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = (System.getenv('GIGANTIC_EXEC_MODE') == 'slurm') ? 'slurm' : 'local'
    queueSize = (System.getenv('GIGANTIC_QUEUE_SIZE') ?: '70').toInteger()
    exitReadTimeout = '15min'
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = (System.getenv('GIGANTIC_EXEC_MODE') == 'slurm') ? 'slurm' : 'local'

    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = -1

    cpus = (System.getenv('GIGANTIC_LOCAL_STEP_CPUS') ?: '4').toInteger()
    memory = "${(System.getenv('GIGANTIC_LOCAL_STEP_MEMORY_GB') ?: '30')} GB"
    time = "${(System.getenv('GIGANTIC_LOCAL_STEP_TIME_HOURS') ?: '2')}h"

    // ----------------------------------------------------------------------
    // local_step: lightweight orchestration (validate, summarize, log).
    // ----------------------------------------------------------------------
    withLabel: 'local_step' {
        executor = 'local'
        cpus = (System.getenv('GIGANTIC_LOCAL_STEP_CPUS') ?: '4').toInteger()
        memory = "${(System.getenv('GIGANTIC_LOCAL_STEP_MEMORY_GB') ?: '30')} GB"
        time = "${(System.getenv('GIGANTIC_LOCAL_STEP_TIME_HOURS') ?: '2')}h"
    }

    // ----------------------------------------------------------------------
    // identify_per_species: per-species hotspot computation (filter + identify).
    // Light — runs per-species local concurrent, or SLURM if execution_mode==slurm.
    // ----------------------------------------------------------------------
    withLabel: 'identify_per_species' {
        executor = (System.getenv('GIGANTIC_EXEC_MODE') == 'slurm') ? 'slurm' : 'local'
        clusterOptions = (System.getenv('GIGANTIC_EXEC_MODE') == 'slurm') ? "--account=${System.getenv('GIGANTIC_SLURM_ACCOUNT') ?: 'moroz'} --qos=${System.getenv('GIGANTIC_SLURM_QOS') ?: 'moroz'}" : ''
        cpus = (System.getenv('GIGANTIC_IDENTIFY_CPUS') ?: '2').toInteger()
        memory = "${(System.getenv('GIGANTIC_IDENTIFY_MEMORY_GB') ?: '8')} GB"
        time = "${(System.getenv('GIGANTIC_IDENTIFY_TIME_HOURS') ?: '1')}h"
    }
}

// ============================================================================
// PROFILES (slurm enables array batching for the per-species fan-out)
// ============================================================================

profiles {
    slurm {
        process {
            withLabel: 'identify_per_species' {
                array = 70
            }
        }
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-hotspots-identify_hotspots'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Per-species chromosomal hotspot identification (modernized port of GIGANTIC_0 hotspots-paper code)'
    mainScript = 'main.nf'
    version = '0.1.0'
    nextflowVersion = '>=26.0.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = 'OUTPUT_pipeline/pipeline_timeline.html'
    overwrite = true
}

report {
    enabled = true
    file = 'OUTPUT_pipeline/pipeline_report.html'
    overwrite = true
}

trace {
    enabled = true
    file = 'OUTPUT_pipeline/pipeline_trace.txt'
    overwrite = true
}
