/*
 * GIGANTIC hotspots - BLOCK_self_blast NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 May 04
 * Human: Eric Edsinger
 *
 * NextFlow 26+ strict config DSL forbids variable declarations and `import`
 * statements at the top level. To stay compatible we read all dynamic
 * settings via environment variables that RUN-workflow.sh exports from
 * START_HERE-user_config.yaml. Users still edit only the yaml — the env
 * vars are an internal implementation detail.
 *
 * Static defaults are hard-coded inline; per-run overrides come from yaml
 * via -params-file (consumed in main.nf as params.*) or via env vars
 * (consumed in this config).
 */

// ============================================================================
// PARAMS — defaults only; -params-file from RUN-workflow.sh overrides at runtime
// ============================================================================

params {
    // Input
    proteomes_dir         = '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/species70_gigantic_T1_proteomes'
    blast_db_dir          = '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/species70_gigantic_T1_blastp'
    gigantic_species_list = 'INPUT_user/gigantic_species_list.txt'

    // Output
    output_dir = 'OUTPUT_pipeline'

    // BLAST
    evalue              = '1e-3'
    outfmt              = '6'
    num_threads         = 5

    // Chunking
    sequences_per_chunk = 600

    // Project
    project_name      = 'GIGANTIC'
    conda_environment = 'ai_gigantic_hotspots'
}

// ============================================================================
// EXECUTOR
// ============================================================================
// GIGANTIC_EXEC_MODE is exported by RUN-workflow.sh from yaml execution_mode.
// GIGANTIC_QUEUE_SIZE caps SLURM concurrent submissions.

executor {
    name = (System.getenv('GIGANTIC_EXEC_MODE') == 'slurm') ? 'slurm' : 'local'
    queueSize = (System.getenv('GIGANTIC_QUEUE_SIZE') ?: '200').toInteger()
    // /blue filesystem can lag on .exitcode flush; default 270s timeout
    // false-positives tasks. 15min gives margin.
    exitReadTimeout = '15min'
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = (System.getenv('GIGANTIC_EXEC_MODE') == 'slurm') ? 'slurm' : 'local'

    // Fail-fast for unlabeled processes; per-label retry settings below
    // can override. maxErrors = -1 lets per-label retries fire.
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = -1

    cpus = (System.getenv('GIGANTIC_LOCAL_STEP_CPUS') ?: '4').toInteger()
    memory = "${(System.getenv('GIGANTIC_LOCAL_STEP_MEMORY_GB') ?: '30')} GB"
    time = "${(System.getenv('GIGANTIC_LOCAL_STEP_TIME_HOURS') ?: '2')}h"

    // ----------------------------------------------------------------------
    // local_step: lightweight orchestration (validate, chunk, merge, log).
    // Always local; never SLURM-submitted.
    // ----------------------------------------------------------------------
    withLabel: 'local_step' {
        executor = 'local'
        cpus = (System.getenv('GIGANTIC_LOCAL_STEP_CPUS') ?: '4').toInteger()
        memory = "${(System.getenv('GIGANTIC_LOCAL_STEP_MEMORY_GB') ?: '30')} GB"
        time = "${(System.getenv('GIGANTIC_LOCAL_STEP_TIME_HOURS') ?: '2')}h"
    }

    // ----------------------------------------------------------------------
    // blastp_chunk: per-chunk blastp fan-out.
    //   - SLURM mode: each chunk → SLURM array task on burst QOS (the
    //     `slurm` profile below adds the `array = 100` directive)
    //   - Local mode: chunks run as concurrent local processes
    //
    // Dynamic resource escalation on retry:
    //   Attempt 1: 5 cpu /  30 GB  (covers ~99% of chunks)
    //   Attempt 2: 10 cpu / 60 GB  (large-proteome edge cases)
    //   Attempt 3: 15 cpu / 90 GB  (last-resort retry)
    // ----------------------------------------------------------------------
    withLabel: 'blastp_chunk' {
        executor = (System.getenv('GIGANTIC_EXEC_MODE') == 'slurm') ? 'slurm' : 'local'
        clusterOptions = (System.getenv('GIGANTIC_EXEC_MODE') == 'slurm') ? "--account=${System.getenv('GIGANTIC_BURST_ACCOUNT') ?: 'moroz'} --qos=${System.getenv('GIGANTIC_BURST_QOS') ?: 'moroz-b'}" : ''

        cpus   = { (System.getenv('GIGANTIC_BLASTP_CPUS') ?: '5').toInteger() * task.attempt }
        memory = { "${(System.getenv('GIGANTIC_BLASTP_MEMORY_GB') ?: '30').toInteger() * task.attempt} GB" }
        time   = "${(System.getenv('GIGANTIC_BLASTP_TIME_HOURS') ?: '5')}h"

        errorStrategy = 'retry'
        maxRetries = 2
        maxErrors = -1
    }
}

// ============================================================================
// PROFILES (conditional config blocks; activated by `-profile <name>`)
// ============================================================================
// RUN-workflow.sh adds `-profile slurm` automatically when
// execution_mode == "slurm" in the yaml. The `array` directive is only
// valid for grid executors and only when > 1, so it lives here.

profiles {
    slurm {
        process {
            withLabel: 'blastp_chunk' {
                array = 100
            }
        }
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-hotspots-self_blast'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Per-species self-BLASTp with SLURM array fan-out (env-var driven)'
    mainScript = 'main.nf'
    version = '0.1.0'
    nextflowVersion = '>=26.0.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = 'OUTPUT_pipeline/pipeline_timeline.html'
    overwrite = true
}

report {
    enabled = true
    file = 'OUTPUT_pipeline/pipeline_report.html'
    overwrite = true
}

trace {
    enabled = true
    file = 'OUTPUT_pipeline/pipeline_trace.txt'
    overwrite = true
}
