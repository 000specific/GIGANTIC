/*
 * GIGANTIC homolog_counts - BLOCK homolog_counts NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 May 20 / patched 2026 May 25
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml directly via -params-file. NextFlow
 * loads it natively; params.X.Y.Z here mirror the yaml shape (nested
 * keys preserved).
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - No top-level `def` declarations mixed with config blocks.
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested + flat).

params {
    project {
        name = 'homolog_counts'
    }
    inputs {
        species70_phyloname_map  = ''
        orthogroups_orthohmm_dir = ''
        trees_gene_groups_dir    = ''
        trees_gene_families_dir  = ''
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    cpus = 4
    memory_gb = 16
    time_hours = 4
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.cpus
    memory = "${params.memory_gb} GB"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Conservative defaults (overridden by labels below)
    cpus = 1
    memory = '4 GB'
    time = '1h'

    withLabel: 'local' {
        cpus = 1
        memory = '2 GB'
        time = '30m'
    }

    withLabel: 'counting' {
        cpus = params.cpus
        memory = "${params.memory_gb} GB"
        time = "${params.time_hours}h"
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-homolog_counts'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Per-species70 homolog count tables from multiple upstream subprojects'
    version = '1.1.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output.base_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output.base_dir}/pipeline_report.html"
    overwrite = true
}
