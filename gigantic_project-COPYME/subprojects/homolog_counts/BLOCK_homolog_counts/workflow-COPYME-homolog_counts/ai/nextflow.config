/*
 * GIGANTIC homolog_counts - BLOCK homolog_counts NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 May 20
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from that YAML and configures NextFlow internals.
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File( "${projectDir}/../START_HERE-user_config.yaml" )
    if ( configFile.exists() ) {
        def yaml = new Yaml()
        return yaml.load( configFile.text )
    }
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// PARAMETERS (from START_HERE-user_config.yaml)
// ============================================================================

params {
    // Input paths (validated in main.nf)
    species70_phyloname_map  = userConfig?.inputs?.species70_phyloname_map  ?: ''
    orthogroups_orthohmm_dir = userConfig?.inputs?.orthogroups_orthohmm_dir ?: ''
    trees_gene_groups_dir    = userConfig?.inputs?.trees_gene_groups_dir    ?: ''
    trees_gene_families_dir  = userConfig?.inputs?.trees_gene_families_dir  ?: ''

    // Output
    output_dir = userConfig?.output?.base_dir ?: 'OUTPUT_pipeline'

    // Resource sizing — top-level YAML keys shared with the SLURM
    // submission block in RUN-workflow.sh. CLI flags (--cpus, --memory_gb)
    // from RUN-workflow.sh take precedence over the YAML defaults below.
    cpus      = userConfig?.cpus      ?: 4
    memory_gb = userConfig?.memory_gb ?: 16
    memory    = "${memory_gb} GB"
    time      = "${userConfig?.time_hours ?: 4}h"

    // Project metadata
    project_name = userConfig?.project?.name ?: 'homolog_counts'
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.cpus
    memory = params.memory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Conservative defaults (overridden by labels below)
    cpus = 1
    memory = '4 GB'
    time = '1h'

    withLabel: 'local' {
        cpus = 1
        memory = '2 GB'
        time = '30m'
    }

    withLabel: 'counting' {
        cpus = params.cpus
        memory = params.memory
        time = params.time
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-homolog_counts'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Per-species70 homolog count tables from multiple upstream subprojects'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
    overwrite = true
}
