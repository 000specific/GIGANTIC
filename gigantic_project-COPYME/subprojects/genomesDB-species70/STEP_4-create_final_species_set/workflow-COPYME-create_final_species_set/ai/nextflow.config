/*
 * GIGANTIC genomesDB STEP_4 - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 February 27
 * Human: Eric Edsinger
 *
 * Purpose: Load user configuration from YAML and set process defaults
 */

// ============================================================================
// LOAD YAML CONFIGURATION
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    System.err.println("WARNING: START_HERE-user_config.yaml not found at ${configFile.absolutePath}. Using default parameters.")
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// PARAMETERS FROM YAML
// ============================================================================

params {
    // Input paths (via output_to_input convention)
    step2_proteomes = userConfig?.inputs?.step2_proteomes ?: "../../output_to_input/STEP_2-standardize_and_evaluate/gigantic_proteomes_cleaned"
    step3_blastp = userConfig?.inputs?.step3_blastp ?: "../../output_to_input/STEP_3-databases/gigantic-T1-blastp"
    step2_genome_annotations = userConfig?.inputs?.step2_genome_annotations ?: "../../output_to_input/STEP_2-standardize_and_evaluate/gigantic_genome_annotations"
    selected_species = userConfig?.inputs?.selected_species ?: "INPUT_user/selected_species.txt"

    // Output settings
    output_dir = userConfig?.output?.base_dir ?: "OUTPUT_pipeline"

    // Project name (from config)
    project_name = userConfig?.project?.name ?: "my_project"
}

// ============================================================================
// EXECUTOR CONFIGURATION
// ============================================================================

executor {
    name = 'local'
    cpus = 4
    memory = '16 GB'
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Fail-fast error handling (GIGANTIC standard for research pipelines)
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = 0

    // Default resources (STEP_4 is lightweight - just copying files)
    cpus = 2
    memory = '8 GB'
    time = '1h'

    withLabel: 'local' {
        executor = 'local'
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-genomesDB-STEP_4'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Create final species set for downstream subprojects'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

report {
    enabled = false
}

timeline {
    enabled = false
}

dag {
    enabled = false
}
