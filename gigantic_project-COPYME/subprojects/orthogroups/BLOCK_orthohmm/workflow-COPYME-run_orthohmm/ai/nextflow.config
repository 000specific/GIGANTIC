/*
 * GIGANTIC Orthogroups - BLOCK OrthoHMM NextFlow Configuration
 * AI: Claude Code | Opus 4.6 / Opus 4.7 | 2026 March 06 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (nested keys preserved).
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested).
//
// NOTE: orthohmm.cpus and orthohmm.memory MUST be set in the user yaml
// before running — main.nf validates this and errors out clearly if unset.

params {
    project {
        name = 'GIGANTIC'
    }
    inputs {
        proteomes_dir = '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/speciesN_gigantic_T1_proteomes'
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    orthohmm {
        cpus = 0                          // MUST be set in user yaml
        memory = '0 GB'                   // MUST be set in user yaml
        evalue = '0.0001'
        single_copy_threshold = '0.5'
        time = '48h'
    }
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.orthohmm.cpus
    memory = params.orthohmm.memory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources
    cpus = 1
    memory = '4 GB'
    time = '2h'

    // Label-specific resources
    withLabel: 'local' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withLabel: 'orthohmm' {
        cpus = params.orthohmm.cpus
        memory = params.orthohmm.memory
        time = params.orthohmm.time
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-Orthogroups-OrthoHMM'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'OrthoHMM orthogroup detection with validation and QC'
    version = '1.1.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output.base_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output.base_dir}/pipeline_report.html"
    overwrite = true
}
