/*
 * GIGANTIC Orthogroups - BLOCK OrthoHMM NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 March 06
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from config.yaml and sets up NextFlow internals.
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// PARAMETERS (from START_HERE-user_config.yaml)
// ============================================================================

params {
    // Input: proteomes directory from genomesDB
    proteomes_dir = userConfig?.inputs?.proteomes_dir ?: '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/speciesN_gigantic_T1_proteomes'

    // Output settings
    output_dir = userConfig?.output?.base_dir ?: 'OUTPUT_pipeline'

    // OrthoHMM parameters (cpus and memory MUST be set in START_HERE-user_config.yaml)
    cpus = userConfig?.orthohmm?.cpus ?: 0
    memory = userConfig?.orthohmm?.memory ?: '0 GB'
    evalue = userConfig?.orthohmm?.evalue ?: '0.0001'
    single_copy_threshold = userConfig?.orthohmm?.single_copy_threshold ?: '0.5'

    // Project metadata
    project_name = userConfig?.project?.name ?: 'GIGANTIC'

    // Conda environment
    conda_environment = userConfig?.conda?.environment ?: 'ai_gigantic_orthogroups_orthohmm'
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.cpus
    memory = params.memory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources
    cpus = 1
    memory = '4 GB'
    time = '2h'

    // Label-specific resources
    withLabel: 'local' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
    }

    withLabel: 'orthohmm' {
        cpus = params.cpus
        memory = params.memory
        time = '48h'
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-Orthogroups-OrthoHMM'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'OrthoHMM orthogroup detection with validation and QC'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
}
