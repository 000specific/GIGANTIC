/*
 * GIGANTIC Orthogroups - BLOCK_broccoli NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 April (revised: yaml-driven + execution_mode threaded)
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from the user yaml and sets up NextFlow internals.
 *
 * `execution_mode` (yaml) drives ALL executor decisions:
 *   - "slurm" : run_broccoli uses its own SLURM allocation
 *   - "local" : every process runs in the local executor on the calling
 *               machine (suitable for big-memory single-node compute)
 *
 * NOTE: Broccoli does not yet have a parallel fan-out architecture (the
 * BLOCK_orthohmm_GIGANTIC / BLOCK_orthofinder_array pattern). The
 * `run_broccoli` process is monolithic. Future development may add a
 * fan-out for the DIAMOND step using a similar -op/-b escape hatch.
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// EXECUTION MODE (the user-facing top-level switch)
// ============================================================================

def executionMode = userConfig?.execution_mode ?: 'local'
def isSlurm = executionMode == 'slurm'

// ============================================================================
// PER-PROCESS RESOURCES (from START_HERE-user_config.yaml)
// ============================================================================
// HiPerGator convention: max memory_gb = 7.5 × cpus.

def runBroccoliCpus = userConfig?.resources?.run_broccoli?.cpus ?: 8
def runBroccoliMemory = "${userConfig?.resources?.run_broccoli?.memory_gb ?: 64} GB"
def runBroccoliTime = "${userConfig?.resources?.run_broccoli?.time_hours ?: 72}h"

def localStepCpus = userConfig?.resources?.local_step?.cpus ?: 4
def localStepMemory = "${userConfig?.resources?.local_step?.memory_gb ?: 30} GB"
def localStepTime = "${userConfig?.resources?.local_step?.time_hours ?: 2}h"

// ============================================================================
// SLURM-SPECIFIC SETTINGS (only used when executionMode == 'slurm')
// ============================================================================

def slurmAccount = userConfig?.slurm_account ?: 'moroz'
def slurmQos = userConfig?.slurm_qos ?: 'moroz'

// ============================================================================
// PARAMS (accessible inside main.nf)
// ============================================================================

params {
    // Input
    proteomes_dir = userConfig?.inputs?.proteomes_dir ?: '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/speciesN_gigantic_T1_proteomes'

    // Output
    output_dir = userConfig?.output?.base_dir ?: 'OUTPUT_pipeline'

    // Broccoli parameters
    cpus = runBroccoliCpus
    tree_method = userConfig?.broccoli?.tree_method ?: 'nj'  // nj, me, or ml

    // Project metadata
    project_name = userConfig?.project?.name ?: 'GIGANTIC'

    // Conda environment
    conda_environment = userConfig?.conda?.environment ?: 'ai_gigantic_orthogroups_broccoli'
}

// ============================================================================
// EXECUTOR DEFAULTS
// ============================================================================
// Default executor follows execution_mode. When local, NextFlow autodetects
// the calling machine's cpus/memory.

executor {
    name = isSlurm ? 'slurm' : 'local'

    $slurm {
        // Increase the timeout NextFlow waits for a SLURM task's `.exitcode`
        // file to appear after the job finishes. Default is 270 seconds (4.5
        // min). On HiPerGator's shared /blue filesystem, flush latency can
        // exceed that under load — NextFlow then false-positives the task as
        // "terminated for unknown reason" and aborts the pipeline. 15 min
        // gives ample margin without slowing happy-path runs.
        exitReadTimeout = '15min'
    }
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = isSlurm ? 'slurm' : 'local'

    // Fail-fast for unlabeled processes (errorStrategy = 'terminate' aborts
    // on any error; maxRetries = 0 means no retry attempts).
    //
    // maxErrors = -1 (no global cumulative cap) so any per-process
    // errorStrategy = 'retry' override can actually fire when needed. The
    // global default of 0 was observed to block label-level retries in
    // this NextFlow version even when a label specified maxErrors = -1.
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = -1

    // ----------------------------------------------------------------------
    // Lightweight orchestration steps — always run on local executor.
    // ----------------------------------------------------------------------
    withName: 'validate_proteomes' {
        executor = 'local'
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'convert_headers' {
        executor = 'local'
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'restore_identifiers' {
        executor = 'local'
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'generate_summary_statistics' {
        executor = 'local'
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'qc_analysis_per_species' {
        executor = 'local'
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    // ----------------------------------------------------------------------
    // run_broccoli: the heavy compute step. Runs Broccoli's 4-step internal
    // pipeline (k-mer clustering, DIAMOND + tree construction, network
    // analysis, pairwise ortholog extraction).
    //
    //   - SLURM mode: own SLURM allocation on regular moroz QOS
    //   - Local mode: runs on the local machine; the calling machine MUST
    //                 have at least `run_broccoli.cpus` cpus and `memory_gb`
    //                 of RAM available
    // ----------------------------------------------------------------------
    withName: 'run_broccoli' {
        executor = isSlurm ? 'slurm' : 'local'
        clusterOptions = isSlurm ? "--account=${slurmAccount} --qos=${slurmQos}" : ''
        cpus = runBroccoliCpus
        memory = runBroccoliMemory
        time = runBroccoliTime
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-Orthogroups-Broccoli'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Broccoli orthogroup detection (driven by yaml execution_mode for local or SLURM)'
    mainScript = 'main.nf'
    version = '1.1.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.output_dir}/pipeline_trace.txt"
    overwrite = true
}
