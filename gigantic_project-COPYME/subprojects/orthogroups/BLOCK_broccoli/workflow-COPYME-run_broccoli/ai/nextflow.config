/*
 * GIGANTIC Orthogroups - BLOCK_broccoli NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 April / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (nested keys preserved).
 *
 * `execution_mode` (yaml) drives ALL executor decisions:
 *   - "slurm" : run_broccoli uses its own SLURM allocation
 *   - "local" : every process runs in the local executor on the calling
 *               machine (suitable for big-memory single-node compute)
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level (rejected by 26.x parser).
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 *
 * NOTE: Broccoli does not yet have a parallel fan-out architecture (the
 * BLOCK_orthohmm_GIGANTIC / BLOCK_orthofinder_array pattern). The
 * `run_broccoli` process is monolithic.
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested).

params {
    project {
        name = 'GIGANTIC'
    }
    inputs {
        proteomes_dir = '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/speciesN_gigantic_T1_proteomes'
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    broccoli {
        tree_method = 'nj'   // nj | me | ml
    }
    resources {
        // HiPerGator convention: max memory_gb = 7.5 × cpus.
        run_broccoli {
            cpus = 8
            memory_gb = 64
            time_hours = 72
        }
        local_step {
            cpus = 4
            memory_gb = 30
            time_hours = 2
        }
    }

    // Execution mode + SLURM defaults
    execution_mode = 'local'
    slurm_account = 'moroz'
    slurm_qos = 'moroz'
}

// ============================================================================
// EXECUTION MODE (the user-facing top-level switch)
// ============================================================================
// NextFlow 26.x strict-DSL: `def X = ...` cannot be mixed with config blocks.
// Use ( params.execution_mode == 'slurm' ) inline below where needed.

// ============================================================================
// EXECUTOR DEFAULTS
// ============================================================================
// Default executor follows execution_mode. When local, NextFlow autodetects
// the calling machine's cpus/memory.

executor {
    name = ( params.execution_mode == 'slurm' ) ? 'slurm' : 'local'

    $slurm {
        // Increase the timeout NextFlow waits for a SLURM task's `.exitcode`
        // file to appear after the job finishes. Default is 270 seconds (4.5
        // min). On HiPerGator's shared /blue filesystem, flush latency can
        // exceed that under load — NextFlow then false-positives the task as
        // "terminated for unknown reason" and aborts the pipeline. 15 min
        // gives ample margin without slowing happy-path runs.
        exitReadTimeout = '15min'
    }
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = ( params.execution_mode == 'slurm' ) ? 'slurm' : 'local'

    // Fail-fast for unlabeled processes (errorStrategy = 'terminate' aborts
    // on any error; maxRetries = 0 means no retry attempts).
    //
    // maxErrors = -1 (no global cumulative cap) so any per-process
    // errorStrategy = 'retry' override can actually fire when needed.
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = -1

    // ----------------------------------------------------------------------
    // Lightweight orchestration steps — always run on local executor.
    // ----------------------------------------------------------------------
    withName: 'validate_proteomes' {
        executor = 'local'
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'convert_headers' {
        executor = 'local'
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'restore_identifiers' {
        executor = 'local'
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'generate_summary_statistics' {
        executor = 'local'
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'qc_analysis_per_species' {
        executor = 'local'
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    // ----------------------------------------------------------------------
    // run_broccoli: the heavy compute step. Runs Broccoli's 4-step internal
    // pipeline (k-mer clustering, DIAMOND + tree construction, network
    // analysis, pairwise ortholog extraction).
    //
    //   - SLURM mode: own SLURM allocation on regular moroz QOS
    //   - Local mode: runs on the local machine; the calling machine MUST
    //                 have at least `run_broccoli.cpus` cpus and `memory_gb`
    //                 of RAM available
    // ----------------------------------------------------------------------
    withName: 'run_broccoli' {
        executor = ( params.execution_mode == 'slurm' ) ? 'slurm' : 'local'
        clusterOptions = ( params.execution_mode == 'slurm' ) ? "--account=${params.slurm_account} --qos=${params.slurm_qos}" : ''
        cpus = params.resources.run_broccoli.cpus
        memory = "${params.resources.run_broccoli.memory_gb} GB"
        time = "${params.resources.run_broccoli.time_hours}h"
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-Orthogroups-Broccoli'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Broccoli orthogroup detection (driven by yaml execution_mode for local or SLURM)'
    mainScript = 'main.nf'
    version = '1.2.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output.base_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output.base_dir}/pipeline_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.output.base_dir}/pipeline_trace.txt"
    overwrite = true
}
