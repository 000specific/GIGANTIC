// AI: Claude Code | Opus 4.6 | 2026 March 30 | Purpose: Nextflow configuration for orthogroup clustering comparison pipeline
// Human: Eric Edsinger

// Orthogroup Clustering Comparison Pipeline Configuration

params {
    // Input manifest (relative to workflow root, resolved to absolute in main.nf)
    manifest = '../INPUT_user/clustering_manifest.tsv'

    // Project name (for run log)
    project_name = 'GIGANTIC'

    // Pipeline output directory
    output_dir = '../OUTPUT_pipeline'

    // Overlap analysis sampling (higher = more accurate, slower)
    overlap_sample_size = 500000
}

process {
    // Fail fast - stop immediately on first failure (GIGANTIC convention)
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0

    withName: 'compare_clustering_runs_table' {
        cpus = 1
        memory = '32 GB'
        time = '2h'
    }

    withName: 'compare_clustering_runs_visualization' {
        cpus = 1
        memory = '16 GB'
        time = '1h'
    }
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
}
