/*
 * GIGANTIC Orthogroups - BLOCK_orthofinder_array NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 April 27 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (nested keys preserved).
 *
 * `execution_mode` (yaml) drives ALL executor decisions in this config:
 *   - "slurm" : diamond_pair uses SLURM burst executor with array fan-out;
 *               orthofinder_finalize uses its own SLURM allocation
 *   - "local" : every process runs in the local executor on the calling
 *               machine (suitable for big-memory single-node compute, e.g.,
 *               a 100-cpu workstation without SLURM)
 *
 * The yaml is the user-facing contract.
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested).

params {
    project {
        name = 'GIGANTIC'
    }
    inputs {
        proteomes_dir = '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/speciesN_gigantic_T1_proteomes'
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    orthofinder {
        search_method = 'diamond'   // diamond or blast
        mcl_inflation = '1.5'
    }
    resources {
        // HiPerGator convention: max memory_gb = 7.5 × cpus.
        diamond_pair {
            cpus = 2
            memory_gb = 15
            time_hours = 2
        }
        orthofinder_finalize {
            cpus = 48
            memory_gb = 360
            time_hours = 96
        }
        local_step {
            cpus = 4
            memory_gb = 30
            time_hours = 2
        }
    }

    // Execution mode + SLURM defaults
    execution_mode = 'local'
    slurm_account = 'moroz'
    slurm_qos = 'moroz'
    slurm_burst_account = 'moroz'
    slurm_burst_qos = 'moroz-b'
}

// ============================================================================
// EXECUTION MODE
// ============================================================================
// NextFlow 26.x strict-DSL: `def X = ...` cannot be mixed with config blocks.
// Use ( params.execution_mode == 'slurm' ) inline below where needed.

// ============================================================================
// EXECUTOR DEFAULTS
// ============================================================================

executor {
    name = ( params.execution_mode == 'slurm' ) ? 'slurm' : 'local'

    $slurm {
        // queueSize caps the diamond_pair fan-out concurrency in SLURM mode.
        // Sized to fit just under HiPerGator's burst capacity for the moroz group.
        queueSize = 450

        // Increase the timeout NextFlow waits for a SLURM task's `.exitcode`
        // file to appear after the job finishes. Default is 270s; HiPerGator's
        // shared /blue filesystem flush latency can exceed that under load.
        exitReadTimeout = '15min'
    }
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = ( params.execution_mode == 'slurm' ) ? 'slurm' : 'local'

    // Fail-fast for unlabeled processes. maxErrors = -1 (no global cap) so
    // per-label `errorStrategy = 'retry'` overrides can actually fire.
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = -1

    cpus = params.resources.local_step.cpus
    memory = "${params.resources.local_step.memory_gb} GB"
    time = "${params.resources.local_step.time_hours}h"

    // ----------------------------------------------------------------------
    // local_step: lightweight Python/bash steps (validate, prepare, extract
    // commands, pool, standardize output, summary, QC, log).
    // ----------------------------------------------------------------------
    withLabel: 'local_step' {
        executor = 'local'
        cpus = params.resources.local_step.cpus
        memory = "${params.resources.local_step.memory_gb} GB"
        time = "${params.resources.local_step.time_hours}h"
    }

    // ----------------------------------------------------------------------
    // diamond_pair: thousands of pairwise DIAMOND searches.
    //   - SLURM mode: each pair = one SLURM array task on burst QOS
    //   - Local mode: pairs run as concurrent local processes
    // ----------------------------------------------------------------------
    withLabel: 'diamond_pair' {
        executor = ( params.execution_mode == 'slurm' ) ? 'slurm' : 'local'
        clusterOptions = ( params.execution_mode == 'slurm' ) ? "--account=${params.slurm_burst_account} --qos=${params.slurm_burst_qos}" : ''
        cpus = params.resources.diamond_pair.cpus
        memory = "${params.resources.diamond_pair.memory_gb} GB"
        time = "${params.resources.diamond_pair.time_hours}h"
        errorStrategy = 'retry'
        maxRetries = 2
        maxErrors = -1
        array = ( params.execution_mode == 'slurm' ) ? 100 : 1
    }

    // ----------------------------------------------------------------------
    // orthofinder_finalize: -b resume, runs clustering + tree inference +
    // reconciliation. Own SLURM allocation on regular moroz QOS, or local.
    // ----------------------------------------------------------------------
    withLabel: 'orthofinder_finalize' {
        executor = ( params.execution_mode == 'slurm' ) ? 'slurm' : 'local'
        clusterOptions = ( params.execution_mode == 'slurm' ) ? "--account=${params.slurm_account} --qos=${params.slurm_qos}" : ''
        cpus = params.resources.orthofinder_finalize.cpus
        memory = "${params.resources.orthofinder_finalize.memory_gb} GB"
        time = "${params.resources.orthofinder_finalize.time_hours}h"
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-Orthogroups-OrthoFinder-array'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'OrthoFinder orthogroup detection with parallel-DIAMOND fan-out (SLURM array or local concurrency, driven by yaml execution_mode)'
    mainScript = 'main.nf'
    version = '1.2.0'
    nextflowVersion = '>=23.10.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output.base_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output.base_dir}/pipeline_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.output.base_dir}/pipeline_trace.txt"
    overwrite = true
}
