/*
 * GIGANTIC Orthogroups - BLOCK_orthofinder_array NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 April 27 (revised: execution_mode threaded)
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from the user yaml and sets up NextFlow internals.
 *
 * `execution_mode` (yaml) drives ALL executor decisions in this config:
 *   - "slurm" : diamond_pair uses SLURM burst executor with array fan-out;
 *               orthofinder_finalize uses its own SLURM allocation
 *   - "local" : every process runs in the local executor on the calling
 *               machine (suitable for big-memory single-node compute, e.g.,
 *               a 100-cpu workstation without SLURM)
 *
 * The yaml is the user-facing contract. nextflow.config never hardwires
 * executor choices that bypass it.
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// EXECUTION MODE (the user-facing top-level switch)
// ============================================================================

def executionMode = userConfig?.execution_mode ?: 'local'
def isSlurm = executionMode == 'slurm'

// ============================================================================
// PER-LABEL RESOURCES (from START_HERE-user_config.yaml)
// ============================================================================
// HiPerGator convention: max memory_gb = 7.5 × cpus.

def diamondPairCpus = userConfig?.resources?.diamond_pair?.cpus ?: 2
def diamondPairMemory = "${userConfig?.resources?.diamond_pair?.memory_gb ?: 15} GB"
def diamondPairTime = "${userConfig?.resources?.diamond_pair?.time_hours ?: 2}h"

def orthofinderFinalizeCpus = userConfig?.resources?.orthofinder_finalize?.cpus ?: 48
def orthofinderFinalizeMemory = "${userConfig?.resources?.orthofinder_finalize?.memory_gb ?: 360} GB"
def orthofinderFinalizeTime = "${userConfig?.resources?.orthofinder_finalize?.time_hours ?: 96}h"

def localStepCpus = userConfig?.resources?.local_step?.cpus ?: 4
def localStepMemory = "${userConfig?.resources?.local_step?.memory_gb ?: 30} GB"
def localStepTime = "${userConfig?.resources?.local_step?.time_hours ?: 2}h"

// ============================================================================
// SLURM-SPECIFIC SETTINGS (only used when executionMode == 'slurm')
// ============================================================================

def slurmAccount = userConfig?.slurm_account ?: 'moroz'
def slurmQos = userConfig?.slurm_qos ?: 'moroz'
def slurmBurstAccount = userConfig?.slurm_burst_account ?: 'moroz'
def slurmBurstQos = userConfig?.slurm_burst_qos ?: 'moroz-b'

// ============================================================================
// PARAMS (from START_HERE-user_config.yaml, accessible inside main.nf)
// ============================================================================

params {
    // Input
    proteomes_dir = userConfig?.inputs?.proteomes_dir ?: '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/speciesN_gigantic_T1_proteomes'

    // Output
    output_dir = userConfig?.output?.base_dir ?: 'OUTPUT_pipeline'

    // OrthoFinder parameters
    search_method = userConfig?.orthofinder?.search_method ?: 'diamond'
    mcl_inflation = userConfig?.orthofinder?.mcl_inflation ?: '1.5'

    // Project metadata
    project_name = userConfig?.project?.name ?: 'GIGANTIC'

    // Conda environment
    conda_environment = userConfig?.conda?.environment ?: 'ai_gigantic_orthogroups'

    // Resource hints (used by some scripts that need to know their cpu allocation)
    diamond_pair_cpus = diamondPairCpus
    orthofinder_finalize_cpus = orthofinderFinalizeCpus
}

// ============================================================================
// EXECUTOR DEFAULTS
// ============================================================================
// Default executor follows execution_mode. When local, NextFlow autodetects
// the calling machine's cpus/memory. When slurm, queueSize caps the
// fan-out concurrency at burst pool capacity.

executor {
    name = isSlurm ? 'slurm' : 'local'

    // SLURM executor concurrency cap for the diamond_pair fan-out (only
    // applied when isSlurm). Sized to fit just under HiPerGator's burst
    // capacity for the moroz group.
    $slurm {
        queueSize = 450

        // Increase the timeout NextFlow waits for a SLURM task's `.exitcode`
        // file to appear after the job finishes. Default is 270 seconds.
        // On HiPerGator's shared /blue filesystem, flush latency can exceed
        // that under load — NextFlow then false-positives the task as
        // "terminated for unknown reason" and aborts the pipeline. 15 min
        // gives ample margin without slowing happy-path runs.
        exitReadTimeout = '15min'
    }
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    // Default executor follows execution_mode (overridable per-label below).
    executor = isSlurm ? 'slurm' : 'local'

    // Fail-fast for unlabeled processes. maxErrors = -1 (no global cap) so
    // per-label `errorStrategy = 'retry'` overrides can actually fire when
    // needed — a global of 0 was observed to block label-level retries in
    // this NextFlow version.
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = -1

    cpus = localStepCpus
    memory = localStepMemory
    time = localStepTime

    // ----------------------------------------------------------------------
    // local_step: lightweight Python/bash steps (validate, prepare, extract
    // commands, pool, standardize output, summary, QC, log).
    // Always runs on the local executor.
    // ----------------------------------------------------------------------
    withLabel: 'local_step' {
        executor = 'local'
        cpus = localStepCpus
        memory = localStepMemory
        time = localStepTime
    }

    // ----------------------------------------------------------------------
    // diamond_pair: ~4,830 pairwise DIAMOND searches.
    //   - SLURM mode: each pair = one SLURM array task on burst QOS
    //   - Local mode: pairs run as concurrent local processes
    //
    // Retry on transient failures: thousands of tasks means a few will hit
    // glitches; per-task retry is far cheaper than restarting the whole step.
    // ----------------------------------------------------------------------
    withLabel: 'diamond_pair' {
        executor = isSlurm ? 'slurm' : 'local'
        clusterOptions = isSlurm ? "--account=${slurmBurstAccount} --qos=${slurmBurstQos}" : ''
        cpus = diamondPairCpus
        memory = diamondPairMemory
        time = diamondPairTime
        errorStrategy = 'retry'
        maxRetries = 2
        maxErrors = -1

        // SLURM job arrays (slurm mode only). NextFlow ignores `array` for
        // the local executor.
        array = isSlurm ? 100 : 1
    }

    // ----------------------------------------------------------------------
    // orthofinder_finalize: -b resume, runs clustering + tree inference +
    // reconciliation.
    //   - SLURM mode: own SLURM allocation on regular moroz QOS
    //   - Local mode: runs on the local machine; the calling machine MUST
    //                 have at least `orthofinder_finalize.cpus` cpus and
    //                 `memory_gb` of RAM available
    // ----------------------------------------------------------------------
    withLabel: 'orthofinder_finalize' {
        executor = isSlurm ? 'slurm' : 'local'
        clusterOptions = isSlurm ? "--account=${slurmAccount} --qos=${slurmQos}" : ''
        cpus = orthofinderFinalizeCpus
        memory = orthofinderFinalizeMemory
        time = orthofinderFinalizeTime
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-Orthogroups-OrthoFinder-array'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'OrthoFinder orthogroup detection with parallel-DIAMOND fan-out (SLURM array or local concurrency, driven by yaml execution_mode)'
    mainScript = 'main.nf'
    version = '1.1.0'
    nextflowVersion = '>=23.10.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.output_dir}/pipeline_trace.txt"
    overwrite = true
}
