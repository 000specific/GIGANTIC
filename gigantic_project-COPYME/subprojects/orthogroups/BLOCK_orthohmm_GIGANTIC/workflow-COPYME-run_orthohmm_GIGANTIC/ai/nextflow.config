/*
 * GIGANTIC Orthogroups - BLOCK_orthohmm_GIGANTIC NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 April 26 (revised: execution_mode threaded)
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from the user yaml and sets up NextFlow internals.
 *
 * `execution_mode` (yaml) drives ALL executor decisions in this config:
 *   - "slurm" : phmmer_pair uses SLURM burst executor with array fan-out;
 *               orthohmm_finalize uses its own SLURM allocation
 *   - "local" : every process runs in the local executor on the calling
 *               machine (suitable for big-memory single-node compute, e.g.,
 *               a 100-cpu workstation without SLURM)
 *
 * The yaml is the user-facing contract. nextflow.config never hardwires
 * executor choices that bypass it.
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// EXECUTION MODE (the user-facing top-level switch)
// ============================================================================
// `executionMode` is read once at config-load time. Every executor decision
// below derives from it. To run locally on a workstation: set
// `execution_mode: "local"` in the yaml. To run on SLURM: set
// `execution_mode: "slurm"`.

def executionMode = userConfig?.execution_mode ?: 'local'
def isSlurm = executionMode == 'slurm'

// ============================================================================
// PER-LABEL RESOURCES (from START_HERE-user_config.yaml)
// ============================================================================
// HiPerGator convention: max memory_gb = 7.5 × cpus.
// Defaults shown match the COPYME yaml values.

def phmmerPairCpus = userConfig?.resources?.phmmer_pair?.cpus ?: 5
def phmmerPairMemoryBaseGb = userConfig?.resources?.phmmer_pair?.memory_gb ?: 37
def phmmerPairMemory = "${phmmerPairMemoryBaseGb} GB"
def phmmerPairTime = "${userConfig?.resources?.phmmer_pair?.time_hours ?: 10}h"

def orthohmmFinalizeCpus = userConfig?.resources?.orthohmm_finalize?.cpus ?: 40
def orthohmmFinalizeMemory = "${userConfig?.resources?.orthohmm_finalize?.memory_gb ?: 300} GB"
def orthohmmFinalizeTime = "${userConfig?.resources?.orthohmm_finalize?.time_hours ?: 24}h"

def localStepCpus = userConfig?.resources?.local_step?.cpus ?: 4
def localStepMemory = "${userConfig?.resources?.local_step?.memory_gb ?: 30} GB"
def localStepTime = "${userConfig?.resources?.local_step?.time_hours ?: 2}h"

// ============================================================================
// SLURM-SPECIFIC SETTINGS (only used when executionMode == 'slurm')
// ============================================================================

def slurmAccount = userConfig?.slurm_account ?: 'moroz'
def slurmQos = userConfig?.slurm_qos ?: 'moroz'
def slurmBurstAccount = userConfig?.slurm_burst_account ?: 'moroz'
def slurmBurstQos = userConfig?.slurm_burst_qos ?: 'moroz-b'

// ============================================================================
// PARAMS (from START_HERE-user_config.yaml, accessible inside main.nf)
// ============================================================================

params {
    // Input
    proteomes_dir = userConfig?.inputs?.proteomes_dir ?: '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/speciesN_gigantic_T1_proteomes'

    // Output
    output_dir = userConfig?.output?.base_dir ?: 'OUTPUT_pipeline'

    // OrthoHMM parameters
    evalue = userConfig?.orthohmm?.evalue ?: '0.0001'
    single_copy_threshold = userConfig?.orthohmm?.single_copy_threshold ?: '0.5'

    // Project metadata
    project_name = userConfig?.project?.name ?: 'GIGANTIC'

    // Conda environment
    conda_environment = userConfig?.conda?.environment ?: 'ai_gigantic_orthogroups_orthohmm'

    // Resource hints (used by some scripts that need to know their cpu allocation)
    phmmer_pair_cpus = phmmerPairCpus
    orthohmm_finalize_cpus = orthohmmFinalizeCpus
}

// ============================================================================
// EXECUTOR DEFAULTS
// ============================================================================
// Default executor follows execution_mode. When local, NextFlow autodetects
// the calling machine's cpus/memory. When slurm, queueSize caps the
// fan-out concurrency at burst pool capacity.

// SLURM executor concurrency cap (yaml-driven).
// SLURM rejects submissions with QOSGrpCpuLimit if (queueSize × cpus_per_task)
// exceeds the group's burst CPU pool. The yaml exposes `slurm_queue_size`
// so users on different clusters / different burst caps can tune without
// editing this file.

def slurmQueueSize = userConfig?.slurm_queue_size ?: 200

executor {
    name = isSlurm ? 'slurm' : 'local'

    $slurm {
        queueSize = slurmQueueSize
        // Increase the timeout NextFlow waits for a SLURM task's `.exitcode`
        // file to appear after the job finishes. Default is 270 seconds (4.5
        // min). On HiPerGator's shared /blue filesystem, flush latency can
        // exceed that under load — NextFlow then false-positives the task as
        // "terminated for unknown reason" and aborts the pipeline. 15 min
        // gives ample margin without slowing happy-path runs.
        exitReadTimeout = '15min'
    }
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    // Default executor follows execution_mode (overridable per-label below).
    executor = isSlurm ? 'slurm' : 'local'

    // Fail-fast for unlabeled processes (errorStrategy = 'terminate' aborts
    // on any error; maxRetries = 0 means no retry attempts).
    //
    // maxErrors = -1 (no global cumulative cap) so per-label errorStrategy
    // = 'retry' can actually fire when needed. The global default of 0 was
    // observed to block label-level retries in this NextFlow version even
    // when the label specified maxErrors = -1.
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = -1

    // Default resources
    cpus = localStepCpus
    memory = localStepMemory
    time = localStepTime

    // ----------------------------------------------------------------------
    // local_step: lightweight Python/bash steps (validate, convert headers,
    // extract phmmer cmds, pool, restore IDs, summary, QC, log).
    // Always runs on the local executor — these are orchestration steps
    // that don't benefit from cluster submission.
    // ----------------------------------------------------------------------
    withLabel: 'local_step' {
        executor = 'local'
        cpus = localStepCpus
        memory = localStepMemory
        time = localStepTime
    }

    // ----------------------------------------------------------------------
    // phmmer_pair: ~4,830 species pair phmmer calls.
    //   - SLURM mode: each pair becomes its own SLURM array task on burst QOS
    //   - Local mode: pairs run as concurrent local processes (limited by
    //                 local cpu count; suitable for big-memory workstations)
    //
    // Plan B dynamic resource escalation on retry:
    //   Attempt 1: 5 cpu  /  37 GB    (covers ~99% of pairs)
    //   Attempt 2: 10 cpu /  74 GB    (handles big-vs-big sponge pairs)
    //   Attempt 3: 15 cpu / 112 GB    (last-resort for pathological pairs)
    // Phmmer scales poorly past ~8 cpus; the extra cpus on retry mainly
    // unlock more memory under HiPerGator's 7.5×cpus rule.
    // ----------------------------------------------------------------------
    withLabel: 'phmmer_pair' {
        executor = isSlurm ? 'slurm' : 'local'
        clusterOptions = isSlurm ? "--account=${slurmBurstAccount} --qos=${slurmBurstQos}" : ''

        cpus   = { phmmerPairCpus * task.attempt }
        memory = { "${phmmerPairMemoryBaseGb * task.attempt} GB" }
        time   = phmmerPairTime

        errorStrategy = 'retry'
        maxRetries = 2
        // Override the global `maxErrors = 0` — that fail-fast setting is
        // for single-shot scripts where any error is a bug. For the fan-out
        // with thousands of tasks, transient failures are expected on a
        // few; retry is the safety net. -1 disables the cumulative-error
        // limit so each task gets its full 2 retries before contributing
        // to a final-failure count.
        maxErrors = -1

        // SLURM job arrays (slurm mode only). Bundles up to 100 tasks per
        // sbatch submission. NextFlow ignores `array` for the local executor.
        // Per UF HiPerGator policy, arrays of <10K elements need no prior
        // approval (~4,830 < 10K).
        array = isSlurm ? 100 : 1
    }

    // ----------------------------------------------------------------------
    // orthohmm_finalize: --start search_res, runs Steps 2-5 in one process.
    //   - SLURM mode: own SLURM allocation on regular moroz QOS
    //   - Local mode: runs on the local machine; the calling machine MUST
    //                 have at least `orthohmm_finalize.cpus` cpus and
    //                 `memory_gb` of RAM available
    //
    // Sized to cover the peak memory observed in BLOCK_orthohmm RUN_4
    // (216 GB) with margin. MCL clustering and edge graph building are
    // the typical memory bottlenecks here.
    // ----------------------------------------------------------------------
    withLabel: 'orthohmm_finalize' {
        executor = isSlurm ? 'slurm' : 'local'
        clusterOptions = isSlurm ? "--account=${slurmAccount} --qos=${slurmQos}" : ''
        cpus = orthohmmFinalizeCpus
        memory = orthohmmFinalizeMemory
        time = orthohmmFinalizeTime
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-Orthogroups-OrthoHMM-GIGANTIC'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'OrthoHMM orthogroup detection with parallel-phmmer fan-out (SLURM array or local concurrency, driven by yaml execution_mode)'
    mainScript = 'main.nf'
    version = '1.1.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.output_dir}/pipeline_trace.txt"
    overwrite = true
}
