/*
 * GIGANTIC Orthogroups - BLOCK_orthohmm_GIGANTIC NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 April 26 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (nested keys preserved).
 *
 * `execution_mode` (yaml) drives ALL executor decisions in this config:
 *   - "slurm" : phmmer_pair uses SLURM burst executor with array fan-out;
 *               orthohmm_finalize uses its own SLURM allocation
 *   - "local" : every process runs in the local executor on the calling
 *               machine (suitable for big-memory single-node compute, e.g.,
 *               a 100-cpu workstation without SLURM)
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested).

params {
    project {
        name = 'GIGANTIC'
    }
    inputs {
        proteomes_dir = '../../../genomesDB/output_to_input/STEP_4-create_final_species_set/speciesN_gigantic_T1_proteomes'
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    orthohmm {
        evalue = '0.0001'
        single_copy_threshold = '0.5'
    }
    resources {
        // HiPerGator convention: max memory_gb = 7.5 × cpus.
        phmmer_pair {
            cpus = 5
            memory_gb = 37
            time_hours = 10
        }
        orthohmm_finalize {
            cpus = 40
            memory_gb = 300
            time_hours = 24
        }
        local_step {
            cpus = 4
            memory_gb = 30
            time_hours = 2
        }
    }

    // Execution mode + SLURM defaults
    execution_mode = 'local'
    slurm_account = 'moroz'
    slurm_qos = 'moroz'
    slurm_burst_account = 'moroz'
    slurm_burst_qos = 'moroz-b'
    slurm_queue_size = 200    // queueSize cap for phmmer_pair fan-out
}

// ============================================================================
// EXECUTION MODE
// ============================================================================

def isSlurm = ( params.execution_mode == 'slurm' )

// ============================================================================
// EXECUTOR DEFAULTS
// ============================================================================

executor {
    name = isSlurm ? 'slurm' : 'local'

    $slurm {
        // SLURM rejects submissions with QOSGrpCpuLimit if
        // (queueSize × cpus_per_task) exceeds the group's burst CPU pool.
        // Tune slurm_queue_size in the yaml for different clusters / caps.
        queueSize = params.slurm_queue_size

        // Increase the timeout NextFlow waits for a SLURM task's `.exitcode`
        // file to appear after the job finishes. Default is 270s; HiPerGator's
        // shared /blue filesystem flush latency can exceed that under load.
        exitReadTimeout = '15min'
    }
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = isSlurm ? 'slurm' : 'local'

    // Fail-fast for unlabeled processes. maxErrors = -1 (no global cap) so
    // per-label `errorStrategy = 'retry'` overrides can actually fire.
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = -1

    // Default resources
    cpus = params.resources.local_step.cpus
    memory = "${params.resources.local_step.memory_gb} GB"
    time = "${params.resources.local_step.time_hours}h"

    // ----------------------------------------------------------------------
    // local_step: lightweight Python/bash steps (validate, convert headers,
    // extract phmmer cmds, pool, restore IDs, summary, QC, log).
    // ----------------------------------------------------------------------
    withLabel: 'local_step' {
        executor = 'local'
        cpus = params.resources.local_step.cpus
        memory = "${params.resources.local_step.memory_gb} GB"
        time = "${params.resources.local_step.time_hours}h"
    }

    // ----------------------------------------------------------------------
    // phmmer_pair: thousands of species pair phmmer calls.
    //   - SLURM mode: each pair becomes its own SLURM array task on burst QOS
    //   - Local mode: pairs run as concurrent local processes
    //
    // Plan B dynamic resource escalation on retry:
    //   Attempt 1: phmmer_pair.cpus  / phmmer_pair.memory_gb
    //   Attempt 2: 2× cpus / 2× memory (handles big-vs-big sponge pairs)
    //   Attempt 3: 3× cpus / 3× memory (last-resort for pathological pairs)
    // ----------------------------------------------------------------------
    withLabel: 'phmmer_pair' {
        executor = isSlurm ? 'slurm' : 'local'
        clusterOptions = isSlurm ? "--account=${params.slurm_burst_account} --qos=${params.slurm_burst_qos}" : ''

        cpus   = { params.resources.phmmer_pair.cpus * task.attempt }
        memory = { "${params.resources.phmmer_pair.memory_gb * task.attempt} GB" }
        time   = "${params.resources.phmmer_pair.time_hours}h"

        errorStrategy = 'retry'
        maxRetries = 2
        maxErrors = -1

        // SLURM job arrays bundle up to 100 tasks per sbatch submission.
        array = isSlurm ? 100 : 1
    }

    // ----------------------------------------------------------------------
    // orthohmm_finalize: --start search_res, runs Steps 2-5 in one process.
    //   - SLURM mode: own SLURM allocation on regular moroz QOS
    //   - Local mode: runs on the local machine; the calling machine MUST
    //                 have at least orthohmm_finalize.cpus + memory_gb available
    // ----------------------------------------------------------------------
    withLabel: 'orthohmm_finalize' {
        executor = isSlurm ? 'slurm' : 'local'
        clusterOptions = isSlurm ? "--account=${params.slurm_account} --qos=${params.slurm_qos}" : ''
        cpus = params.resources.orthohmm_finalize.cpus
        memory = "${params.resources.orthohmm_finalize.memory_gb} GB"
        time = "${params.resources.orthohmm_finalize.time_hours}h"
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-Orthogroups-OrthoHMM-GIGANTIC'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'OrthoHMM orthogroup detection with parallel-phmmer fan-out (SLURM array or local concurrency, driven by yaml execution_mode)'
    mainScript = 'main.nf'
    version = '1.2.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output.base_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output.base_dir}/pipeline_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.output.base_dir}/pipeline_trace.txt"
    overwrite = true
}
