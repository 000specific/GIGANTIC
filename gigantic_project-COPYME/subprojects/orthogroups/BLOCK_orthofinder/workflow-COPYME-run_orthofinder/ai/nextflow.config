// AI: Claude Code | Opus 4.6 / Opus 4.7 | 2026 February 28 / patched 2026 May 24
// Human: Eric Edsinger
//
// OrthoFinder Pipeline Configuration
// Runs OrthoFinder orthogroup detection with validation, statistics, and QC.
//
// NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
// RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
// .params.json and NextFlow loads it via -params-file. All yaml keys
// become params.X.Y.Z here through that mechanism — params shape mirrors
// the yaml shape (flat in this workflow's case).
//
// NextFlow 26.x compatibility:
//   - No `import org.yaml.snakeyaml.Yaml` at top-level.
//   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).

nextflow.enable.dsl = 2

params {
    // Input: proteomes directory from genomesDB
    proteomes_dir = '../../genomesDB/output_to_input/STEP_4-create_final_species_set/speciesN_gigantic_T1_proteomes'

    // Pipeline output
    output_dir = 'OUTPUT_pipeline'

    // OrthoFinder parameters
    cpus = 8
    search_method = 'diamond'  // diamond or blast
    mcl_inflation = '1.5'

    // Project metadata (used in the write_run_log step)
    project_name = 'GIGANTIC'
}

process {
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0

    withName: 'validate_proteomes' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'prepare_proteomes' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'run_orthofinder' {
        cpus = params.cpus
        memory = '64 GB'
        time = '72h'
    }

    withName: 'standardize_output' {
        cpus = 1
        memory = '8 GB'
        time = '1h'
    }

    withName: 'generate_summary_statistics' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'qc_analysis_per_species' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
}
