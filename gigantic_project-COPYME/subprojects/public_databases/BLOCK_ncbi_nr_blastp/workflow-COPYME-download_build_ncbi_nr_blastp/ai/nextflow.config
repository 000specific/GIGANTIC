// AI: Claude Code | Opus 4.6 | 2026 March 09 | Purpose: Nextflow configuration for NCBI nr BLAST protein database pipeline
// Human: Eric Edsinger

// NCBI nr BLAST Protein Database Pipeline Configuration
// Downloads nr FASTA from NCBI and builds a BLAST protein database using makeblastdb

// Load user configuration from START_HERE-user_config.yaml
import org.yaml.snakeyaml.Yaml

def user_config_file = file( "${projectDir}/../START_HERE-user_config.yaml" )
def user_config = new Yaml().load( user_config_file.text )

params {
    // NCBI nr download URL
    nr_url = user_config.ncbi_nr.url

    // Output directory
    output_dir = user_config.output.base_dir

    // makeblastdb threads
    threads = user_config.makeblastdb.threads

    // Conda environment name
    conda_environment = user_config.conda.environment

    // Project name
    project_name = user_config.project.name
}

process {
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0

    withName: 'download_ncbi_nr' {
        cpus = 1
        memory = '8 GB'
        time = '48h'
    }

    withName: 'build_blastp_database' {
        cpus = 15
        memory = '100 GB'
        time = '24h'
    }

    withName: 'validate_database' {
        cpus = 1
        memory = '4 GB'
        time = '1h'
    }

    withName: 'write_run_log' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output_dir}/pipeline_report.html"
    overwrite = true
}
