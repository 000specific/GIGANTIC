/*
 * GIGANTIC Public Databases - NCBI nr DIAMOND Database NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 March 09
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from the config yaml and sets up NextFlow internals.
 *
 * Pattern: A (Sequential) - executor = 'local'
 * All processes run sequentially within a single job.
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    // Config file is in workflow root (parent of ai/ folder where this file lives)
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// ============================================================================
// PARAMETERS (from START_HERE-user_config.yaml)
// ============================================================================

params {
    // Project settings
    project_name = userConfig?.project?.name ?: "my_project"

    // NCBI nr settings
    nr_url = userConfig?.ncbi_nr?.download_url ?: "https://ftp.ncbi.nlm.nih.gov/blast/db/FASTA/nr.gz"

    // Output settings
    output_dir = userConfig?.output?.base_dir ?: "OUTPUT_pipeline"

    // DIAMOND settings
    diamond_threads = userConfig?.diamond?.threads ?: 15

    // Conda environment
    conda_environment = userConfig?.conda?.environment ?: "ai_gigantic_public_databases"
}

// ============================================================================
// EXECUTOR - Pattern A (Sequential/Local)
// ============================================================================

executor {
    name = 'local'
    cpus = 15
    memory = '100 GB'
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Per-process resource labels
    withName: 'download_ncbi_nr' {
        cpus = 1
        memory = '8 GB'
        time = '48h'
    }

    withName: 'build_diamond_database' {
        cpus = 15
        memory = '100 GB'
        time = '24h'
    }

    withName: 'validate_database' {
        cpus = 1
        memory = '4 GB'
        time = '1h'
    }

    withName: 'write_run_log' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-NCBI-nr-DIAMOND'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Download NCBI nr protein database and build DIAMOND search database'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output_dir}/nextflow_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output_dir}/nextflow_report.html"
    overwrite = true
}
