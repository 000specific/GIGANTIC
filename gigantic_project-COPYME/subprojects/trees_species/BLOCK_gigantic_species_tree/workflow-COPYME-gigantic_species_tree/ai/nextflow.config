/*
 * GIGANTIC trees_species - BLOCK_gigantic_species_tree - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 April 13
 * Human: Eric Edsinger
 *
 * Purpose: Load user configuration from START_HERE-user_config.yaml and set
 *          process defaults for the gigantic_species_tree workflow.
 *
 * ==============================================================================
 *  ⚠️  IMPORTANT FOR USERS:
 *
 *  Values that users normally adjust for a specific run live in
 *  `START_HERE-user_config.yaml` — NOT here. This config reads that yaml
 *  directly (see loadConfig() below) and maps fields into `params` without
 *  duplication.
 *
 *  Do NOT hand-edit the param values below to override the yaml — the yaml
 *  is the single source of truth. Edit `START_HERE-user_config.yaml` instead.
 * ==============================================================================
 */

// ============================================================================
// LOAD YAML CONFIGURATION
// ============================================================================

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested + flat).
// NextFlow 26.x compatibility: no SnakeYAML import; no top-level def
// declarations; YAML loading happens via -params-file directly.

params {
    species_set_name = 'speciesN'
    input_files {
        species_tree = 'INPUT_user/species_tree.newick'
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
}

// ============================================================================
// EXECUTOR CONFIGURATION
// ============================================================================

executor {
    name = 'local'
    cpus = 4
    memory = '16 GB'
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Fail-fast error handling (GIGANTIC standard for research pipelines)
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = 0

    // Default resources (most processes in this BLOCK are lightweight)
    cpus = 2
    memory = '4 GB'
    time = '30m'

    withLabel: 'local' {
        executor = 'local'
    }

    // Visualization process (ete3 + Qt can spike memory on large trees)
    withLabel: 'visualization' {
        cpus = 2
        memory = '8 GB'
        time = '30m'
    }
}

// ============================================================================
// CONDA ENVIRONMENT
// ============================================================================
// Reuses the existing trees_species conda environment (already has ete3 + Qt
// for visualization, which is the only external dependency in this BLOCK).

conda {
    enabled = false  // Enable on demand: nextflow run ai/main.nf -with-conda
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-trees_species-BLOCK_gigantic_species_tree'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Standardize and label a user-provided species tree for the GIGANTIC framework'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS (disabled by default — research pipelines generate real artifacts)
// ============================================================================

report {
    enabled = false
}

timeline {
    enabled = false
}

dag {
    enabled = false
}
