/*
 * GIGANTIC trees_species - Permutations and Features - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 April 13
 * Human: Eric Edsinger
 *
 * Purpose: Configuration for the species tree permutations and features pipeline.
 *          Scripts own their data (read/write OUTPUT_pipeline/), NextFlow manages execution order.
 *
 * ==============================================================================
 *  ⚠️  IMPORTANT FOR USERS:
 *
 *  Values that users normally adjust for a specific run live in
 *  `START_HERE-user_config.yaml` — NOT here. `RUN-workflow.sh` reads them
 *  from that yaml and injects them into this config via `nextflow run --KEY value`
 *  so they become `params.KEY` below.
 *
 *  Currently plumbed through from config.yaml:
 *    slurm_account  ← config.yaml `slurm_account`
 *    slurm_qos      ← config.yaml `slurm_qos`
 *
 *  Do NOT hand-edit duplicate values here — that is the out-of-sync footgun
 *  this pattern exists to avoid.
 * ==============================================================================
 */

// Pipeline parameters (overridable from command line or config.yaml)
params {
    // workflow_dir is set by main.nf as "${projectDir}/.." — do NOT set it here.
    // (Config-level params override main.nf script-level assignments in NextFlow,
    //  so an empty default here would silently override the main.nf setting.)

    // Output directory
    output_dir = "OUTPUT_pipeline"

    // SLURM configuration — DO NOT hardcode real values here.
    // These are fallbacks only; RUN-workflow.sh injects real values from
    // START_HERE-user_config.yaml via `nextflow run --slurm_account=X --slurm_qos=Y`.
    // Empty defaults make misconfiguration fail fast rather than silently
    // submitting jobs to someone else's allocation.
    slurm_account = ''
    slurm_qos = ''
}

// Process configuration
process {
    // Error handling: fail fast for research pipelines
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = 0  // Stop immediately on first failure

    // Default resource allocation
    memory = '4 GB'
    time = '1h'
    cpus = 1
}

// Execution profiles
profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue = 'hpg-default'
        process.clusterOptions = "--account=${params.slurm_account} --qos=${params.slurm_qos}"
    }
}

// Conda environment for visualization (script 008)
conda {
    enabled = false  // Enable only when needed: nextflow run main.nf -with-conda
}

// Pipeline reporting
timeline {
    enabled = true
    file = "${params.output_dir}/nextflow_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output_dir}/nextflow_report.html"
    overwrite = true
}
