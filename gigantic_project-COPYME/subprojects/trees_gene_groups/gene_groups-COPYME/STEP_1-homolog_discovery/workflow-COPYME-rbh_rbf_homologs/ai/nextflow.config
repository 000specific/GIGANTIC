/*
 * GIGANTIC trees_gene_groups STEP_1 - NextFlow Configuration
 * Compatible with NextFlow 26.x strict config parser (no `import` statements).
 *
 * User config loading: the STEP_1 orchestrator (workflow-COPYME-rbh_rbf_homologs/RUN-workflow.sh)
 * writes a per-gene-group .params.json (flattened from START_HERE-user_config.yaml)
 * into each gene_group-X/workflow-RUN_01-rbh_rbf_homologs/ at setup time.
 * NextFlow loads it via `-params-file .params.json`.
 */

// ============================================================================
// PARAMETERS (defaults; -params-file overrides)
// ============================================================================

params {
    // Gene family (set per gene group by orchestrator)
    gene_family = null

    // RGS files (absolute or relative to workflow root)
    rgs_full_length_file = null
    rgs_subsequence_file = null
    rgs_file = null               // derived by orchestrator: full-length or subsequence

    // RGS sequence type
    rgs_sequence_is_full_length = true
    include_orphan_rgs = false

    // User input files (relative to workflow root)
    species_keeper_list = "INPUT_user/species_keeper_list.tsv"
    rgs_species_map = "INPUT_user/rgs_species_map.tsv"

    // BLAST databases (absolute paths, resolved by orchestrator)
    blast_databases_dir = null
    rgs_genomes_dir = null

    // Project settings
    project_database = "speciesN_T1-speciesN"
    project_name = "GIGANTIC"

    // BLAST parameters
    blast_evalue = "1e-3"
    blast_threads = 10
    blast_conda_env = "blast"

    // Output
    output_dir = "OUTPUT_pipeline"

    // ========================================================================
    // PER-LABEL PROCESS RESOURCES (overridden by -params-file from YAML)
    // ========================================================================
    // Single source of truth: START_HERE-user_config.yaml. These defaults
    // exist only so nextflow.config is loadable standalone for testing.

    // 'local' label: small/fast Python tasks
    local_cpus       = 2
    local_memory_gb  = 10
    local_time_hours = 1

    // 'blast' label: NCBI BLAST+ commands
    blast_cpus       = 10
    blast_memory_gb  = 75
    blast_time_hours = 24
}

// ============================================================================
// EXECUTOR
// ============================================================================
// Executor pool sized to the heaviest process (blast) so it fits within
// the SLURM block allocation.

executor {
    name = 'local'
    cpus = params.blast_cpus as Integer
    memory = "${params.blast_memory_gb} GB"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    errorStrategy = 'terminate'
    maxErrors = 0

    // Defaults (fallback for any process without a label; match 'local')
    cpus   = params.local_cpus as Integer
    memory = "${params.local_memory_gb} GB"
    time   = "${params.local_time_hours}h"

    withLabel: 'local' {
        cpus   = params.local_cpus as Integer
        memory = "${params.local_memory_gb} GB"
        time   = "${params.local_time_hours}h"
    }

    withLabel: 'blast' {
        cpus   = params.blast_cpus as Integer
        memory = "${params.blast_memory_gb} GB"
        time   = "${params.blast_time_hours}h"
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-trees_gene_groups-STEP_1'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'RBH/RBF homolog discovery via reciprocal BLAST'
    version = '1.0.0'
    nextflowVersion = '>=24.0.0'
}
