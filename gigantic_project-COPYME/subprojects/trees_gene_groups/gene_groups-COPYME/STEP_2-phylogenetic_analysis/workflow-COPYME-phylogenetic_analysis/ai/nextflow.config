/*
 * GIGANTIC trees_gene_groups STEP_2 - NextFlow Configuration
 * Compatible with NextFlow 26.x strict config parser (no `import` statements).
 *
 * User config loading: the STEP_2 orchestrator (workflow-COPYME-phylogenetic_analysis/RUN-workflow.sh)
 * writes a per-gene-group .params.json (flattened from START_HERE-user_config.yaml)
 * into each gene_group-X/workflow-RUN_01-phylogenetic_analysis/ at setup time.
 * NextFlow loads it via `-params-file .params.json`.
 *
 * Conda env: the orchestrator activates `aiG-trees_gene_groups-phylogenetic_analysis`
 * (which contains mafft, clipkit, fasttree, iqtree, veryfasttree) before each
 * nextflow invocation. Process labels do NOT specify per-tool conda envs.
 */

// ============================================================================
// PARAMETERS (defaults; -params-file overrides)
// ============================================================================

params {
    // Gene family
    gene_family = null

    // Paths
    output_dir = "OUTPUT_pipeline"
    output_to_input_dir = "../../../../output_to_input"

    // Project
    project_name = "gene_groups"
    project_database = "speciesN_T1-speciesN"

    // Tree-building toggles
    run_fasttree = true
    run_iqtree = false
    run_veryfasttree = false
    run_phylobayes = false

    // Tool parameters
    clipkit_mode = "smart-gap"

    mafft_maxiterate = 1000
    mafft_bl = 45
    mafft_threads = 50

    iqtree_model = "MFP"
    iqtree_bootstrap = 2000
    iqtree_alrt = 2000
    iqtree_threads = "AUTO"

    veryfasttree_threads = 4

    phylobayes_model = "-cat -gtr"
    phylobayes_generations = 10000
    phylobayes_burnin = 2500
    phylobayes_every = 1

    // Per-tool resources (used by process labels below)
    mafft_cpus = 50;        mafft_memory_gb = 350;       mafft_time_hours = 168
    clipkit_cpus = 4;       clipkit_memory_gb = 16;      clipkit_time_hours = 4
    fasttree_cpus = 4;      fasttree_memory_gb = 16;     fasttree_time_hours = 4
    iqtree_cpus = 50;       iqtree_memory_gb = 350;      iqtree_time_hours = 168
    veryfasttree_cpus = 4;  veryfasttree_memory_gb = 16; veryfasttree_time_hours = 4
    phylobayes_cpus = 4;    phylobayes_memory_gb = 32;   phylobayes_time_hours = 336
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.iqtree_cpus as Integer
    memory = "${params.mafft_memory_gb} GB"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = 0

    withLabel: 'local' {
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }

    withLabel: 'mafft' {
        cpus = params.mafft_cpus as Integer
        memory = "${params.mafft_memory_gb} GB"
        time = "${params.mafft_time_hours}h"
    }

    withLabel: 'clipkit' {
        cpus = params.clipkit_cpus as Integer
        memory = "${params.clipkit_memory_gb} GB"
        time = "${params.clipkit_time_hours}h"
    }

    withLabel: 'fasttree' {
        cpus = params.fasttree_cpus as Integer
        memory = "${params.fasttree_memory_gb} GB"
        time = "${params.fasttree_time_hours}h"
    }

    withLabel: 'iqtree' {
        cpus = params.iqtree_cpus as Integer
        memory = "${params.iqtree_memory_gb} GB"
        time = "${params.iqtree_time_hours}h"
    }

    withLabel: 'veryfasttree' {
        cpus = params.veryfasttree_cpus as Integer
        memory = "${params.veryfasttree_memory_gb} GB"
        time = "${params.veryfasttree_time_hours}h"
    }

    withLabel: 'phylobayes' {
        cpus = params.phylobayes_cpus as Integer
        memory = "${params.phylobayes_memory_gb} GB"
        time = "${params.phylobayes_time_hours}h"
    }
}

// ============================================================================
// REPORTING
// ============================================================================

timeline {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/phylogenetic_analysis_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/phylogenetic_analysis_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/phylogenetic_analysis_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/phylogenetic_analysis_dag.svg"
    overwrite = true
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-trees_gene_groups-STEP_2'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Phylogenetic analysis (MAFFT/ClipKit/FastTree/IQ-TREE/VeryFastTree/PhyloBayes)'
    mainScript = 'main.nf'
    version = '1.0.0'
    nextflowVersion = '>=24.0.0'
}
