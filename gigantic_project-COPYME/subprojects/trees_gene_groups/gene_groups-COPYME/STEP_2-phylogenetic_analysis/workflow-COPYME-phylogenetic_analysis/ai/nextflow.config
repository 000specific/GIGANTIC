// AI: Claude Code | Opus 4.6 | 2026 March 10 | Purpose: NextFlow configuration for STEP_2 phylogenetic analysis
// Human: Eric Edsinger

// ============================================================================
// STEP_2 Phylogenetic Analysis - NextFlow Configuration
// ============================================================================
// Per-tool conda environments and resource allocations.
// NextFlow manages SLURM resources per-process via labels.
// ============================================================================

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// Read per-tool resources from user config
def mafftCpus = userConfig?.resources?.mafft?.cpus ?: 50
def mafftMemory = "${userConfig?.resources?.mafft?.memory_gb ?: 350} GB"
def mafftTime = "${userConfig?.resources?.mafft?.time_hours ?: 168}h"

def clipkitCpus = userConfig?.resources?.clipkit?.cpus ?: 4
def clipkitMemory = "${userConfig?.resources?.clipkit?.memory_gb ?: 16} GB"
def clipkitTime = "${userConfig?.resources?.clipkit?.time_hours ?: 4}h"

def fasttreeCpus = userConfig?.resources?.fasttree?.cpus ?: 4
def fasttreeMemory = "${userConfig?.resources?.fasttree?.memory_gb ?: 16} GB"
def fasttreeTime = "${userConfig?.resources?.fasttree?.time_hours ?: 4}h"

def iqtreeCpus = userConfig?.resources?.iqtree?.cpus ?: 50
def iqtreeMemory = "${userConfig?.resources?.iqtree?.memory_gb ?: 350} GB"
def iqtreeTime = "${userConfig?.resources?.iqtree?.time_hours ?: 168}h"

def veryfasttreeCpus = userConfig?.resources?.veryfasttree?.cpus ?: 4
def veryfasttreeMemory = "${userConfig?.resources?.veryfasttree?.memory_gb ?: 16} GB"
def veryfasttreeTime = "${userConfig?.resources?.veryfasttree?.time_hours ?: 4}h"

def phylobayesCpus = userConfig?.resources?.phylobayes?.cpus ?: 4
def phylobayesMemory = "${userConfig?.resources?.phylobayes?.memory_gb ?: 32} GB"
def phylobayesTime = "${userConfig?.resources?.phylobayes?.time_hours ?: 336}h"

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = mafftCpus > iqtreeCpus ? mafftCpus : iqtreeCpus
    memory = mafftMemory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxRetries = 0
    maxErrors = 0

    // Default resources for local processes (prepare input, clean sequences)
    withLabel: 'local' {
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }

    // MAFFT alignment (resource-intensive)
    withLabel: 'mafft' {
        conda = 'ai_gigantic_mafft'
        cpus = mafftCpus
        memory = mafftMemory
        time = mafftTime
    }

    // ClipKit trimming
    withLabel: 'clipkit' {
        conda = 'ai_gigantic_clipkit'
        cpus = clipkitCpus
        memory = clipkitMemory
        time = clipkitTime
    }

    // FastTree (relatively fast)
    withLabel: 'fasttree' {
        conda = 'ai_gigantic_fasttree'
        cpus = fasttreeCpus
        memory = fasttreeMemory
        time = fasttreeTime
    }

    // IQ-TREE (very resource-intensive)
    withLabel: 'iqtree' {
        conda = 'ai_gigantic_iqtree'
        cpus = iqtreeCpus
        memory = iqtreeMemory
        time = iqtreeTime
    }

    // VeryFastTree (parallelized FastTree - moderate resources)
    withLabel: 'veryfasttree' {
        conda = 'ai_gigantic_veryfasttree'
        cpus = veryfasttreeCpus
        memory = veryfasttreeMemory
        time = veryfasttreeTime
    }

    // PhyloBayes (very slow, moderate memory, long runtime)
    withLabel: 'phylobayes' {
        conda = 'ai_gigantic_phylobayes'
        cpus = phylobayesCpus
        memory = phylobayesMemory
        time = phylobayesTime
    }

    // Visualization is handled by STEP_3-tree_visualization, not here.
}

// Reporting
timeline {
    enabled = true
    file = "${projectDir}/../OUTPUT_pipeline/phylogenetic_analysis_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${projectDir}/../OUTPUT_pipeline/phylogenetic_analysis_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${projectDir}/../OUTPUT_pipeline/phylogenetic_analysis_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${projectDir}/../OUTPUT_pipeline/phylogenetic_analysis_dag.svg"
    overwrite = true
}

// Manifest
manifest {
    name = 'GIGANTIC STEP_2 Phylogenetic Analysis'
    author = 'Eric Edsinger (with AI: Claude Code | Opus 4.6)'
    description = 'Phylogenetic analysis with configurable tree-building methods'
    mainScript = 'main.nf'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}
