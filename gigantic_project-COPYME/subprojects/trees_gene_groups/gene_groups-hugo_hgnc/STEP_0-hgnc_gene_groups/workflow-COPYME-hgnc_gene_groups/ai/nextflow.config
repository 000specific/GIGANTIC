/*
 * GIGANTIC trees_gene_groups STEP_0 - NextFlow Configuration
 * Compatible with NextFlow 26.x strict config parser (no `import` statements).
 *
 * User config loading: RUN-workflow.sh converts START_HERE-user_config.yaml
 * to a flat .params.json and passes it via `-params-file`. NextFlow loads
 * those values directly into `params`. This file just sets defaults +
 * executor/process/reporting/manifest.
 */

// ============================================================================
// PARAMETERS (defaults; -params-file overrides)
// ============================================================================

params {
    // Absolute path to GIGANTIC human T1 proteome .aa file. Resolved by RUN-workflow.sh.
    human_proteome_path = null

    // Output directory (relative to workflow root).
    output_dir = "OUTPUT_pipeline"

    // Resources
    cpus = 4
    memory_gb = 16
    time_hours = 1
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.cpus as Integer
    memory = "${params.memory_gb} GB"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxErrors = 0

    cpus = params.cpus as Integer
    memory = "${params.memory_gb} GB"
    time = "${params.time_hours}h"

    withLabel: 'local' {
        cpus = params.cpus as Integer
        memory = "${params.memory_gb} GB"
        time = "${params.time_hours}h"
    }
}

// ============================================================================
// REPORTING
// ============================================================================

timeline {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_gene_groups_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_gene_groups_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_gene_groups_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_gene_groups_dag.svg"
    overwrite = true
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-trees_gene_groups-STEP_0'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Download HGNC gene groups and generate RGS FASTA files from human proteome'
    version = '1.0.0'
    nextflowVersion = '>=24.0.0'
}
