/*
 * GIGANTIC trees_gene_groups STEP_0 - NextFlow Configuration
 * AI: Claude Code | Opus 4.6 | 2026 March 30
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * This file reads from config.yaml and sets up NextFlow internals.
 */

// ============================================================================
// LOAD USER CONFIGURATION FROM YAML
// ============================================================================

import org.yaml.snakeyaml.Yaml

def loadConfig() {
    // projectDir = ai/ directory (where main.nf lives)
    // Config YAML is one level up at workflow root: projectDir/../START_HERE-user_config.yaml
    def configFile = new File("${projectDir}/../START_HERE-user_config.yaml")
    if (configFile.exists()) {
        def yaml = new Yaml()
        return yaml.load(configFile.text)
    }
    return [:]
}

def userConfig = loadConfig()

// Read resources from user config (flat keys)
def resourceCpus = userConfig?.cpus ?: 4
def resourceMemory = "${userConfig?.memory_gb ?: 16} GB"
def resourceTime = "${userConfig?.time_hours ?: 1}h"

// Resolve relative paths to absolute (needed for NextFlow work directories)
// Config paths are relative to workflow root (projectDir/..)
def workflowRoot = new File("${projectDir}/..").canonicalPath
def resolveConfigPath = { String relPath ->
    if (relPath == null) return null
    def resolved = new File("${workflowRoot}/${relPath}").canonicalPath
    return resolved
}

// ============================================================================
// PARAMETERS (from START_HERE-user_config.yaml)
// ============================================================================

params {
    // Human proteome path - resolved to absolute for NextFlow work directory compatibility
    human_proteome_path = resolveConfigPath(userConfig?.inputs?.human_proteome_path)

    // Output
    output_dir = userConfig?.output?.base_dir ?: "OUTPUT_pipeline"
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = resourceCpus
    memory = resourceMemory
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources (STEP_0 is lightweight)
    cpus = resourceCpus
    memory = resourceMemory
    time = resourceTime

    withLabel: 'local' {
        cpus = resourceCpus
        memory = resourceMemory
        time = resourceTime
    }
}

// ============================================================================
// REPORTING
// ============================================================================

timeline {
    enabled = true
    file = "${projectDir}/../${userConfig?.output?.base_dir ?: 'OUTPUT_pipeline'}/hgnc_gene_groups_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${projectDir}/../${userConfig?.output?.base_dir ?: 'OUTPUT_pipeline'}/hgnc_gene_groups_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${projectDir}/../${userConfig?.output?.base_dir ?: 'OUTPUT_pipeline'}/hgnc_gene_groups_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${projectDir}/../${userConfig?.output?.base_dir ?: 'OUTPUT_pipeline'}/hgnc_gene_groups_dag.svg"
    overwrite = true
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-trees_gene_groups-STEP_0'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Download HGNC gene groups and generate RGS FASTA files from human proteome'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}
