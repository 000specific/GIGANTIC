/*
 * GIGANTIC trees_gene_groups STEP_0-hgnc_based_rgs / workflow-COPYME-hgnc_user_list - NextFlow Configuration
 * Compatible with NextFlow 26.x strict config parser (no `import` statements).
 *
 * User config loading: RUN-workflow.sh converts START_HERE-user_config.yaml
 * to a flat .params.json and passes it via `-params-file`. NextFlow loads
 * those values directly into `params`. This file just sets defaults +
 * executor/process/reporting/manifest.
 */

// ============================================================================
// PARAMETERS (defaults; -params-file overrides)
// ============================================================================

params {
    // Absolute path to the user gene set TSV. Resolved by RUN-workflow.sh.
    user_gene_set_file = null

    // Absolute path to hgnc_complete_set.txt at subproject-level canonical
    // location. The 000 process re-derives this in its script block, but
    // having it in params lets us thread it for traceability/logging.
    hgnc_complete_set_canonical = null

    // Output directory (relative to workflow root).
    output_dir = "OUTPUT_pipeline"

    // Resources
    cpus = 2
    memory_gb = 4
    time_hours = 1
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.cpus as Integer
    memory = "${params.memory_gb} GB"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxErrors = 0

    cpus = params.cpus as Integer
    memory = "${params.memory_gb} GB"
    time = "${params.time_hours}h"

    withLabel: 'local' {
        cpus = params.cpus as Integer
        memory = "${params.memory_gb} GB"
        time = "${params.time_hours}h"
    }
}

// ============================================================================
// REPORTING
// ============================================================================

timeline {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_user_list_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_user_list_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_user_list_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_user_list_dag.svg"
    overwrite = true
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-trees_gene_groups-STEP_0-hgnc_user_list'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Resolve user-supplied human gene symbols to UniProt accessions (via HGNC) and emit per-group RGS FASTAs'
    version = '1.0.0'
    nextflowVersion = '>=24.0.0'
}
