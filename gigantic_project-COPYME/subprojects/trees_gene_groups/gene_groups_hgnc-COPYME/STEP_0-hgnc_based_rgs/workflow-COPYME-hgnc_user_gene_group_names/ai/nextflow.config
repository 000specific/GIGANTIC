/*
 * GIGANTIC trees_gene_groups STEP_0 (workflow-COPYME-hgnc_user_gene_group_names)
 * NextFlow Configuration
 *
 * Compatible with NextFlow 26.x strict config parser (no `import` statements).
 *
 * User config loading: RUN-workflow.sh converts START_HERE-user_config.yaml
 * to a flat .params.json and passes it via `-params-file`. NextFlow loads
 * those values directly into `params`. This file just sets defaults +
 * executor/process/reporting/manifest.
 *
 * Param flattening rationale:
 *   The YAML is nested for human readability (inputs.*, filters.*, output.*),
 *   but RUN-workflow.sh flattens it to top-level keys in .params.json so
 *   `params.<flat>` is used inside main.nf. This matches the proven pattern
 *   in workflow-COPYME-hgnc_database and avoids the strict-mode parser
 *   issues that have surfaced with deeply-nested-config in NF 26.x.
 */

// ============================================================================
// PARAMETERS (defaults; -params-file overrides)
// ============================================================================

params {
    // User-supplied HGNC gene-group names/IDs TSV (REQUIRED).
    // Instance-level path: ../../INPUT_user/user_gene_group_names.tsv
    user_gene_group_names_file = null

    // Absolute path to GIGANTIC human T1 proteome .aa file. Resolved by RUN-workflow.sh.
    human_proteome_path = null

    // Locus-type filter flags (default to MODE 1 database behavior).
    include_pseudogenes = false
    include_non_protein_coding = false

    // Output directory (relative to workflow root).
    output_dir = "OUTPUT_pipeline"

    // Resources
    cpus = 4
    memory_gb = 16
    time_hours = 1
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.cpus as Integer
    memory = "${params.memory_gb} GB"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxErrors = 0

    cpus = params.cpus as Integer
    memory = "${params.memory_gb} GB"
    time = "${params.time_hours}h"

    withLabel: 'local' {
        cpus = params.cpus as Integer
        memory = "${params.memory_gb} GB"
        time = "${params.time_hours}h"
    }
}

// ============================================================================
// REPORTING
// ============================================================================

timeline {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_user_gene_group_names_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_user_gene_group_names_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_user_gene_group_names_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${projectDir}/../${params.output_dir}/hgnc_user_gene_group_names_dag.svg"
    overwrite = true
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-trees_gene_groups-STEP_0-hgnc_user_gene_group_names'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Filter HGNC gene groups by user-supplied names/IDs and generate RGS FASTA files from human proteome'
    version = '1.0.0'
    nextflowVersion = '>=24.0.0,<26.0.0'
}
