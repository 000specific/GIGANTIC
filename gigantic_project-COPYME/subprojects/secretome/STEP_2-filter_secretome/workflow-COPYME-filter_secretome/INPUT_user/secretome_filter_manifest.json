{
  "output_name": "moroz_strict",
  "filters": [
    {
      "feature": "signal_peptide",
      "feature_label": "Has classical signal peptide (SignalP6 slow)",
      "combine_clauses": "all",
      "clauses": [
        {
          "tool": "signalp_slow",
          "column": "signalp_slow_Call",
          "operator": "equals",
          "value": "Sec/SPI"
        }
      ]
    },
    {
      "feature": "transmembrane",
      "feature_label": "No transmembrane regions",
      "combine_clauses": "all",
      "clauses": [
        {
          "tool": "tmbed_counts",
          "column": "tmbed_TM_Helix_Count",
          "operator": "equals",
          "value": 0
        },
        {
          "tool": "tmbed_counts",
          "column": "tmbed_Beta_Barrel_Count",
          "operator": "equals",
          "value": 0
        },
        {
          "tool": "deeploc_tm",
          "column": "deeploc_Transmembrane_Probability",
          "operator": "less_than",
          "value": 0.5
        }
      ]
    },
    {
      "feature": "subcellular_localization",
      "feature_label": "Extracellular destination (DeepLoc)",
      "combine_clauses": "all",
      "clauses": [
        {
          "tool": "deeploc_loc",
          "column": "deeploc_Extracellular_Probability",
          "operator": "greater_or_equal",
          "value": 0.5
        }
      ]
    }
  ]
}
