/*
 * Secretome Filter Pipeline (STEP_2) - NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 May 25
 * Human: Eric Edsinger
 */

nextflow.enable.dsl = 2

params {
    // Structural
    output_dir = 'OUTPUT_pipeline'

    // User-configurable (overridden by START_HERE-user_config.yaml via
    // RUN-workflow.sh -params-file pass-through)
    project_name = 'my_secretome_project'
    filter_manifest_path = 'INPUT_user/secretome_filter_manifest.json'
    evidence_table_dir = ''
    proteome_dir = ''
    annotation_database_dir = ''
    orthogroups_tsv = ''
    blastp_top_hits_dir = ''

    // Run identity (computed by RUN-workflow.sh from existing output_to_input/
    // contents + user's optional output_name from the manifest)
    run_label = 'secretome_001'   // overridden at submit time

    cpus = 8
    memory_gb = 16
    time_hours = 4
}

executor {
    name = 'local'
    cpus = params.cpus
    memory = "${params.memory_gb} GB"
}

process {
    executor = 'local'

    errorStrategy = 'terminate'
    maxErrors = 0

    cpus = 1
    memory = '2 GB'
    time = '30m'

    withName: 'validate_filter_manifest' {
        cpus = 1
        memory = '2 GB'
        time = '5m'
    }

    withName: 'apply_filters_per_species' {
        cpus = 1
        memory = '4 GB'
        time = '15m'
    }

    withName: 'augment_with_derived_columns' {
        cpus = 1
        memory = '4 GB'
        time = '15m'
    }

    withName: 'augment_with_orthogroups' {
        cpus = 1
        memory = '4 GB'
        time = '15m'
    }

    withName: 'augment_with_blastp_top10' {
        cpus = 1
        memory = '4 GB'
        time = '15m'
    }

    withName: 'write_run_log' {
        cpus = 1
        memory = '2 GB'
        time = '5m'
    }
}

manifest {
    name = 'GIGANTIC-secretome-filter_secretome'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Apply a user-defined filter manifest to STEP_1 evidence tables to produce one per-species secretome TSV per run.'
    version = '0.1.0'
    nextflowVersion = '>=21.04.0,<26.0'
}
