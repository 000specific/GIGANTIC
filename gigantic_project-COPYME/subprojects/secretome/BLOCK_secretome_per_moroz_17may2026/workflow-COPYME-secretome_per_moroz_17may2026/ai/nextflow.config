/*
 * GIGANTIC secretome - BLOCK secretome_per_moroz_17may2026 NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 May 21 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (nested keys preserved).
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (nested + flat).

params {
    project {
        name = 'secretome'
    }
    inputs {
        species70_phyloname_map = ''
        // TODO: add upstream input keys here as scripts are wired in.
    }
    output {
        base_dir = 'OUTPUT_pipeline'
    }
    cpus = 4
    memory_gb = 16
    time_hours = 4
}

// ============================================================================
// EXECUTOR
// ============================================================================

executor {
    name = 'local'
    cpus = params.cpus
    memory = "${params.memory_gb} GB"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Conservative defaults (overridden by labels below)
    cpus = 1
    memory = '4 GB'
    time = '1h'

    withLabel: 'local' {
        cpus = 1
        memory = '2 GB'
        time = '30m'
    }

    // TODO: define additional labels (e.g., 'heavy', 'counting') as scripts grow.
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-secretome'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'GIGANTIC secretome subproject — per Moroz lab spec 2026-05-17'
    version = '0.2.0'
    nextflowVersion = '>=21.04.0'
}

// ============================================================================
// REPORTS
// ============================================================================

timeline {
    enabled = true
    file = "${params.output.base_dir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output.base_dir}/pipeline_report.html"
    overwrite = true
}
