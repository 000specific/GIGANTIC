/*
 * Secretome Evidence Table Builder Pipeline - NextFlow Configuration
 * AI: Claude Code | Opus 4.7 | 2026 May 23 / patched 2026 May 24
 * Human: Eric Edsinger
 *
 * NOTE: Users should edit START_HERE-user_config.yaml, NOT this file.
 * RUN-workflow.sh passes the yaml through (json.dump, no flatten) into
 * .params.json and NextFlow loads it via -params-file. All yaml keys
 * become params.X.Y.Z here through that mechanism — params shape mirrors
 * the yaml shape (flat top-level here).
 *
 * NextFlow 26.x compatibility:
 *   - No `import org.yaml.snakeyaml.Yaml` at top-level.
 *   - YAML loading moved to RUN-workflow.sh (Python heredoc -> .params.json).
 *
 * Pattern: A (Sequential) - executor = 'local'
 * All processes run sequentially within a single driver SLURM job.
 */

nextflow.enable.dsl = 2

// ============================================================================
// PARAMETERS (defaults; -params-file from RUN-workflow.sh overrides at runtime)
// ============================================================================
// params shape mirrors START_HERE-user_config.yaml shape (flat top-level keys).

params {
    // Structural params (set here, not in YAML)
    proteome_manifest = "${projectDir}/../INPUT_user/proteome_manifest.tsv"
    output_dir = 'OUTPUT_pipeline'

    // User-configurable params (flat YAML)
    project_name = 'my_project'
    annotation_database_dir = ''
    deeploc_csv_dir = ''
    cpus = 4
    memory_gb = 32
    time_hours = 12
}

// ============================================================================
// EXECUTOR - Pattern A (Sequential/Local)
// ============================================================================

executor {
    name = 'local'
    cpus = params.cpus
    memory = "${params.memory_gb} GB"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    executor = 'local'

    // Error handling - fail fast for research pipelines
    errorStrategy = 'terminate'
    maxErrors = 0

    // Default resources (lightweight processes)
    cpus = 1
    memory = '4 GB'
    time = '2h'

    withName: 'validate_proteome_manifest' {
        cpus = 1
        memory = '4 GB'
        time = '30m'
    }

    withName: 'build_evidence_table' {
        cpus = params.cpus
        memory = "${params.memory_gb} GB"
        time = "${params.time_hours}h"
    }
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'GIGANTIC-secretome-evidence-table'
    author = 'Eric Edsinger (with Claude Code AI)'
    description = 'Build per-species per-protein evidence table from standardized annotation database'
    version = '0.2.0'
    nextflowVersion = '>=21.04.0'
}
