# Software directories (binary models, large downloads, not for git)
**/software/*
!**/software/.gitkeep

# Backup/archive files and directories (prefixed with x_)
# Covers all archived runs, superseded workflows, etc.
x_*

# Early-development files and directories (prefixed with z_).
# Same gitignore mechanism as x_, but different intent:
#   - x_ = staged for eventual removal
#   - z_ = staged as early-development, not for general use yet
# Both sort to the ends of alphabetical listings.
#
# By default, files and dirs prefixed with z_ are gitignored. To make a z_
# DIRECTORY visible on github (so its presence signals future framework
# direction in higher-level docs), add a README.md inside it — README.md
# is the only filename un-ignored within z_* dirs.
#
# The `**/` prefix on the content rules is necessary because z_ dirs can
# live at any depth (e.g., gigantic_project-COPYME/subprojects/z_foo/).
# Without `**/`, the content-ignore rule would only fire at the repo root.
z_*
!**/z_*/
**/z_*/**
!**/z_*/README.md

# NextFlow execution artifacts
work/
.nextflow/
.nextflow.log*
.params.json

# Pipeline outputs (generated, not tracked)
OUTPUT_pipeline/

# Test/production run directories (contain large data, not templates)
workflow-RUN_*/

# GIGANTIC/ai_FYIs/ — local-only historic-dev reference dump (Eric's working
# copy of older docs to consult while walking through subprojects). Not part
# of the shipped framework. The leading `/` anchors this to the GIGANTIC repo
# root, so the rule does NOT match gigantic_project-COPYME/ai/ai_FYIs/ (which
# ships and is the canonical home of gigantic_conventions.md per §30).
/ai_FYIs/

# INPUT_user contents — single staging arena between user data and GIGANTIC.
# Per gigantic_project-COPYME/ai/ai_FYIs/gigantic_conventions.md §17, §20.
# Ships only documentation (*.md at any depth); user content (symlinks,
# manifests, species lists, etc.) stays on local disk only.
/gigantic_project-COPYME/INPUT_user/**
!/gigantic_project-COPYME/INPUT_user/**/
!/gigantic_project-COPYME/INPUT_user/**/*.md

# Gene family instance directories (copies of gene_family_COPYME, contain large data)
gene_family-*/

# Gene group instance directories (copies created by burst scripts, contain large data)
gene_group-*/

# SLURM log directories (generated during cluster runs)
slurm_logs/

# Orchestrator scratch files (per-PID temp species_keeper_list copies; usually
# cleaned up by RUN-workflow.sh but occasionally orphan if interrupted)
.species_keeper_list_*.tsv

# Research notebook contents — personal sandbox + GIGANTIC AI sandbox.
# Per gigantic_project-COPYME/ai/ai_FYIs/gigantic_conventions.md §1, §9, §25.
# See also gigantic_project-COPYME/research_notebook/.gitignore for the
# canonical fine-grained rules at that subtree.
**/research_notebook/*
!**/research_notebook/.gitkeep
!**/research_notebook/README.md
# Un-ignore the two known sandbox subdirectories so git descends into
# them; finer rules below + nested .gitignore handle their contents.
!**/research_notebook/research_ai/
!**/research_notebook/research_user/

# research_ai/ is GIGANTIC's own AI-infrastructure sandbox. Ships its
# docs + sessions/.gitkeep (the capture destination per §9). Captured
# .jsonl.gz session transcripts stay local (nested .gitignore handles).
!**/research_notebook/research_ai/.gitkeep
!**/research_notebook/research_ai/README.md
!**/research_notebook/research_ai/sessions/
!**/research_notebook/research_ai/sessions/.gitkeep

# research_user/ is a personal sandbox per §25 — ships ONLY the
# per-subproject .gitkeep placeholders so users have pre-materialized
# subproject-<X>/ directories. All other content stays local.
# Per gigantic_conventions.md §25.
**/research_notebook/research_user/**
# Re-include subproject-* directories so git can descend into them
# (without these directory un-ignores, the file-level negations below
# never get evaluated — git skips excluded dirs entirely).
!**/research_notebook/research_user/subproject-*/
!**/research_notebook/research_user/subproject-*/**/
# Allow the per-subproject .gitkeep placeholders
!**/research_notebook/research_user/.gitkeep
!**/research_notebook/research_user/**/.gitkeep
# (Toolkits no longer live here per §59 — they live in research_ai/.
# See git history commit 5cb8e3f for the prior toolkit location.)

# Species data directories (large proteome collections, e.g. species43/, species67/, species71/)
species[0-9]*/

# output_to_input contents (workflow-generated data shared between subprojects)
**/output_to_input/*
!**/output_to_input/.gitkeep
!**/output_to_input/README.md

# upload_to_server contents (workflow-generated data for server sharing)
**/upload_to_server/*
!**/upload_to_server/.gitkeep
!**/upload_to_server/README.md
!**/upload_to_server/upload_manifest.tsv

# Large identifier map files (can be 100MB+)
*-map-genome_identifiers.tsv
*-map-sequence_identifiers.tsv

# Large genomic data files
*.aa
*.fa
*.fasta
*.fna
*.gff3
*.gtf
*.pdb
*.psq
*.psa
*.pog
*.pjs
*.pos
*.pto
*.pin
*.phr
*.dmnd

# Python
__pycache__/
*.pyc
*.pyo
.eggs/
*.egg-info/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude Code per-project state (settings, scheduled-task locks)
.claude/
# Exception: gigantic_project-COPYME/.claude/ is the deliberate shipped
# capture-system directory (see ai/ai_FYIs/gigantic_conventions.md §7).
# Ship only settings.json + README.md + AI_GUIDE.md; everything else under
# that .claude/ stays gitignored.
!/gigantic_project-COPYME/.claude/
/gigantic_project-COPYME/.claude/*
!/gigantic_project-COPYME/.claude/settings.json
!/gigantic_project-COPYME/.claude/README.md
!/gigantic_project-COPYME/.claude/AI_GUIDE.md

# Crash core dumps
core.*

# Logs
*.log

# Environment files with secrets
.env
