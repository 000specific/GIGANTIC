# Software directories (binary models, large downloads, not for git)
**/software/*
!**/software/.gitkeep

# Backup/archive run directories (prefixed with x_)
x_workflow-RUN_*/

# NextFlow execution artifacts
work/
.nextflow/
.nextflow.log*

# Pipeline outputs (generated, not tracked)
OUTPUT_pipeline/

# Test/production run directories (contain large data, not templates)
workflow-RUN_*/

# One-off COPYME snapshot used to generate species70 OrthoHMM RUN_1-3 outside the live subproject
# Migrated for archival/audit alongside its RUN dirs; not a canonical template
/gigantic_project-COPYME/subprojects/orthogroups/BLOCK_orthohmm/workflow-COPYME-run_orthohmm_USED_FOR_RUNS_1_TO_3/

# Historical species53 genomesDB build (kept locally as reference; not for the public template)
/gigantic_project-COPYME/subprojects/genomesDB-species53/

# Gene family instance directories (copies of gene_family_COPYME, contain large data)
gene_family-*/

# Gene group instance directories (copies created by burst scripts, contain large data)
gene_group-*/

# SLURM log directories (generated during cluster runs)
slurm_logs/

# Research notebook contents (personal data, not for git)
**/research_notebook/*
!**/research_notebook/.gitkeep
!**/research_notebook/README.md

# Species data directories (large proteome collections, e.g. species43/, species67/, species71/)
species[0-9]*/

# output_to_input contents (workflow-generated data shared between subprojects)
**/output_to_input/*
!**/output_to_input/.gitkeep
!**/output_to_input/README.md

# upload_to_server contents (workflow-generated data for server sharing)
**/upload_to_server/*
!**/upload_to_server/.gitkeep
!**/upload_to_server/README.md
!**/upload_to_server/upload_manifest.tsv

# Large identifier map files (can be 100MB+)
*-map-genome_identifiers.tsv
*-map-sequence_identifiers.tsv

# Large genomic data files
*.aa
*.fa
*.fasta
*.fna
*.gff3
*.gtf
*.pdb
*.psq
*.psa
*.pog
*.pjs
*.pos
*.pto
*.pin
*.phr
*.dmnd

# Python
__pycache__/
*.pyc
*.pyo
.eggs/
*.egg-info/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude Code per-project state (settings, scheduled-task locks)
.claude/

# Crash core dumps
core.*

# Logs
*.log

# Environment files with secrets
.env
